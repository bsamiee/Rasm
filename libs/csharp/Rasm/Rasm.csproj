<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>RhinoCommon-aware geometry foundation and analysis algebra.</Description>
        <CspScope>Domain</CspScope>
    </PropertyGroup>

    <ItemGroup Label="Numerics">
        <PackageReference Include="CSparse" />
        <PackageReference Include="ExtendedNumerics.BigRational" />
        <PackageReference Include="MathNet.Numerics" />
        <PackageReference Include="PeterO.Numbers" />
        <PackageReference Include="System.Numerics.Tensors" />
        <PackageReference Include="TYoshimura.DoubleDouble" />
    </ItemGroup>

    <ItemGroup Label="Performance Primitives">
        <PackageReference Include="CommunityToolkit.HighPerformance" />
    </ItemGroup>

    <ItemGroup Label="Geometry">
        <PackageReference Include="Supercluster.KDTree.Net" />
    </ItemGroup>

    <ItemGroup Label="Computational Geometry">
        <PackageReference Include="MIConvexHull" />
    </ItemGroup>

    <ItemGroup Label="Content Hash">
        <PackageReference Include="System.IO.Hashing" />
    </ItemGroup>

    <ItemGroup Label="Graph Algorithms">
        <PackageReference Include="QuikGraph" />
    </ItemGroup>

    <ItemGroup Label="Kernel Usings">
        <Using Include="Rhino" />
        <Using Include="Rhino.FileIO" />
        <Using Include="Rhino.Geometry" />
        <Using Include="Rhino.Geometry.Intersect" />
        <Using Include="System.Collections.Immutable" />
        <Using Include="System.Globalization" />
        <Using Include="System.Runtime.CompilerServices" />
        <Using Include="System.Runtime.InteropServices" />
    </ItemGroup>

</Project>

{
    "name": "@rasm/services",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./node": {
            "types": "./src/node.ts",
            "import": "./src/node.ts"
        },
        "./provisioning": {
            "types": "./src/provisioning/platform.ts",
            "import": "./src/provisioning/platform.ts"
        }

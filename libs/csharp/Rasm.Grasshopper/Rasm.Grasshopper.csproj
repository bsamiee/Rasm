<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <AssemblyName>Rasm.Grasshopper</AssemblyName>
        <RootNamespace>Rasm.Grasshopper</RootNamespace>
        <Title>Rasm.Grasshopper</Title>
        <Description>GH2 component infrastructure for Rasm: Component&lt;TSpec&gt; contract, Output pipeline, IPort/Port descriptors, PortKind InputAdder/OutputAdder binding, Bridge IDataAccess extensions, Plugin manifest base.</Description>
        <IsGrasshopperAwareProject>true</IsGrasshopperAwareProject>
        <SkipBoundaryExemptionContracts>true</SkipBoundaryExemptionContracts>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../Rasm/Rasm.csproj" />
    </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Shell-private ALC resident for the rebuilt runtime bridge: pipe server, StreamJsonRpc target, idle-pump UI marshal, collectible cargo gate.</Description>
        <AssemblyName>Rasm.Bridge.Shell</AssemblyName>
        <RootNamespace>Rasm.Bridge.Shell</RootNamespace>
        <!-- The shell is NOT a plugin project (the stub owns the .rhp): it is loaded by the
             stub's ShellLoadContext from the deploy dir and ships its full restored closure as
             the deploy set. -->
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
        <InformationalVersion>0.1.0-shell</InformationalVersion>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="StreamJsonRpc" />
        <ProjectReference Include="../Contract/Contract.csproj" />
    </ItemGroup>
</Project>

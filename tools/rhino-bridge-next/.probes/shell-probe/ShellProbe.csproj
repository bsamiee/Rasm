<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>U4 acceptance artifact: drives the rebuilt shell over the rbx- pipe (hello/load/run/unload + busy + proofs 10/13). Not production code; not in Workspace.slnx.</Description>
        <OutputType>Exe</OutputType>
        <RootNamespace>Rasm.Bridge.ShellProbe</RootNamespace>
        <UseWorkspaceLibraries>false</UseWorkspaceLibraries>
        <SkipLocalCSharpAnalyzerReference>true</SkipLocalCSharpAnalyzerReference>
        <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
        <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
        <AnalysisLevel>none</AnalysisLevel>
        <InvariantGlobalization>true</InvariantGlobalization>
        <NoWarn>$(NoWarn);VSTHRD002;VSTHRD103;VSTHRD110;VSTHRD111;VSTHRD200;MA0003;MA0004;MA0007;MA0032;MA0040;MA0042;MA0045;MA0047;MA0134</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="StreamJsonRpc" />
        <ProjectReference Include="../../Rasm.Bridge.Contract/Rasm.Bridge.Contract.csproj" />
    </ItemGroup>
</Project>

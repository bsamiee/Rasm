{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "workspaceLayout": {
        "appsDir": "apps",
        "libsDir": "libs/typescript"
    },
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "production": ["default", "!{projectRoot}/**/*.spec.{ts,tsx,mts,cts}", "!{projectRoot}/**/*.test.{ts,tsx,mts,cts}", "!{projectRoot}/dist"],
        "sharedGlobals": [
            "{workspaceRoot}/biome.json",
            "{workspaceRoot}/package.json",
            "{workspaceRoot}/playwright.config.ts",
            "{workspaceRoot}/pnpm-lock.yaml",
            "{workspaceRoot}/pnpm-workspace.yaml",
            "{workspaceRoot}/stryker.config.json",
            "{workspaceRoot}/tests/containers.json",
            "{workspaceRoot}/tests/contracts/**/*",
            "{workspaceRoot}/tools/biome/*.grit",
            "{workspaceRoot}/tsconfig.base.json",
            "{workspaceRoot}/tsconfig.json",
            "{workspaceRoot}/vite.config.ts",
            "{workspaceRoot}/vite.factory.ts",
            "{workspaceRoot}/vitest.config.ts"
        ]
    },
    "targetDefaults": {
        "build": {
            "cache": true,
            "inputs": ["production", "^production"],
            "outputs": ["{projectRoot}/dist"]
        },
        "typecheck": {
            "cache": true,
            "inputs": ["default", "^production"]
        },
        "test": {
            "cache": true,
            "inputs": ["default", "^production"],
            "outputs": ["{workspaceRoot}/.artifacts/typescript/coverage", "{workspaceRoot}/.artifacts/typescript/test-results"]
        },
        "lint": {
            "cache": true,
            "inputs": ["default", "^production"]
        },
        "e2e": {
            "cache": true,
            "inputs": ["default", "^production"],
            "outputs": ["{workspaceRoot}/.artifacts/typescript/e2e"]
        }
    },
    "plugins": [
        {
            "plugin": "@nx/js/typescript",
            "options": {
                "compiler": "tsc",
                "typecheck": {
                    "targetName": "typecheck",
                    "configName": "tsconfig.json"
                },
                "build": false
            }
        },
        {
            "plugin": "@nx/vite/plugin",
            "options": {
                "buildTargetName": "build",
                "compiler": "tsc",
                "typecheckTargetName": "typecheck"
            }
        },
        {
            "plugin": "@nx/vitest",
            "options": {
                "ciGroupName": "vitest",
                "ciTargetName": "test-ci",
                "testMode": "run",
                "testTargetName": "test"
            }
        },
        {
            "plugin": "@berenddeboer/nx-biome",
            "options": {
                "targetName": "lint"
            }
        },
        {
            "plugin": "@nx/playwright/plugin",
            "options": {
                "ciTargetName": "e2e-ci",
                "targetName": "e2e"
            }
        }
    ],
    "tui": {
        "enabled": true
    }
}

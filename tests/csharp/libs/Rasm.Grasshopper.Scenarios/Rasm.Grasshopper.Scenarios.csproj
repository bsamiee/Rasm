<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Grasshopper UI theme scenario corpus for the rebuilt runtime bridge: repo C# 14 [RhinoScenario] entrypoints discovered in-host by the cargo, compiled with full analyzers and staged via the build-time bridge-closure manifest.</Description>
        <RootNamespace>Rasm.Grasshopper.Scenarios</RootNamespace>
        <!-- Scenario corpus posture: lives under the tests root for per-lib co-location, but it is
             NOT a test project — no xunit, no MTP runner, no Exe entrypoint; entrypoints are
             [RhinoScenario] statics the bridge cargo invokes in-host. Host references must stay
             Private=false so RhinoCommon/Grasshopper2 never enter the bridge-closure assembly
             list (the live host supplies them; staged copies would split type identity inside the
             cargo ALC — GH2 rides the HostAssemblyTable forwarding lane). -->
        <IsTestProject>false</IsTestProject>
        <OutputType>Library</OutputType>
        <HostReferencePrivate>false</HostReferencePrivate>
        <!-- Rasm.Grasshopper.Scenarios sits outside the path-derived aware roots; the GH2 + host
             UI flags are declared here because the props-derived defaults resolve before this
             body runs. -->
        <IsGrasshopperAwareProject>true</IsGrasshopperAwareProject>
        <IsRhinoCommonAwareProject>true</IsRhinoCommonAwareProject>
        <NeedsRhinoHostUiSurface>true</NeedsRhinoHostUiSurface>
        <NoWarn>$(NoWarn);CA1416</NoWarn>
        <CspScope>Test</CspScope>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="../../../../libs/csharp/Rasm.Grasshopper/Rasm.Grasshopper.csproj" />
        <ProjectReference Include="../../_testkit/Rasm.TestKit.csproj" />
    </ItemGroup>
    <Import Project="../../_testkit/Scenarios.targets" />
</Project>

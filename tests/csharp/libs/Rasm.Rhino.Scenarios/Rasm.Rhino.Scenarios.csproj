<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Blocks-theme scenario corpus for the rebuilt runtime bridge: repo C# 14 [RhinoScenario] entrypoints discovered in-host by the cargo, compiled with full analyzers and staged via the build-time bridge-closure manifest.</Description>
        <RootNamespace>Rasm.Rhino.Scenarios</RootNamespace>
        <!-- Scenario corpus posture: lives under the tests root for per-lib co-location, but it is
             NOT a test project — no xunit, no MTP runner, no Exe entrypoint; entrypoints are
             [RhinoScenario] statics the bridge cargo invokes in-host. Host references must stay
             Private=false so RhinoCommon never enters the bridge-closure assembly list (the live
             host supplies it; a staged copy would split type identity inside the cargo ALC). -->
        <IsTestProject>false</IsTestProject>
        <OutputType>Library</OutputType>
        <HostReferencePrivate>false</HostReferencePrivate>
        <!-- Rasm.Rhino.Scenarios sits outside the path-derived RhinoCommon-aware roots; the corpus
             drives RhinoDoc/InstanceDefinition surfaces, so the host compile reference and the
             macOS-annotation posture are declared explicitly (CA1416 rides the host annotation of
             the referenced Rasm.Rhino assembly). -->
        <IsRhinoCommonAwareProject>true</IsRhinoCommonAwareProject>
        <!-- UI-theme scenarios drive Rhino.UI/Eto/System.Drawing host surfaces; the host-UI flags
             are declared here because the props-derived defaults resolve before this body runs. -->
        <IsRhinoUiAwareProject>true</IsRhinoUiAwareProject>
        <NeedsRhinoHostUiSurface>true</NeedsRhinoHostUiSurface>
        <NoWarn>$(NoWarn);CA1416</NoWarn>
        <CspScope>Test</CspScope>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="../../../../libs/csharp/Rasm.Rhino/Rasm.Rhino.csproj" />
        <ProjectReference Include="../../_testkit/Rasm.TestKit.csproj" />
    </ItemGroup>
    <Import Project="../../_testkit/Scenarios.targets" />
</Project>

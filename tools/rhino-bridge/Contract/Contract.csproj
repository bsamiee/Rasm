<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <!-- Wire assembly avoids LanguageExt in the shell ALC; Thinktecture owns generated wire vocabulary. -->
        <AssemblyName>Rasm.Bridge.Contract</AssemblyName>
        <!-- CA1819: arrays are the wire DTO shape. StreamJsonRpc0008 targets MessagePack shape rows unused by SystemTextJsonFormatter. -->
        <NoWarn>$(NoWarn);CA1819;StreamJsonRpc0008</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="StreamJsonRpc" />
        <PackageReference Include="Thinktecture.Runtime.Extensions" />
        <PackageReference Include="Thinktecture.Runtime.Extensions.Json" />
    </ItemGroup>
</Project>

{
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!!**/node_modules",
            "!!**/.cache",
            "!!**/.artifacts",
            "!!**/.claude",
            "!!**/.claude/skills/**/.cache",
            "!!**/.claude/worktrees",
            "!!**/.mypy_cache",
            "!!**/.nx",
            "!!**/.parcel-cache",
            "!!**/.probes",
            "!!**/.pulumi",
            "!!**/.pytest_cache",
            "!!**/.ruff_cache",
            "!!**/.swc",
            "!!**/.venv",
            "!!**/.history",
            "!!**/bin",
            "!!**/obj",
            "!!**/dist",
            "!!**/build",
            "!!**/_tmp",
            "!!**/packages.lock.json",
            "!!**/pnpm-lock.yaml",
            "!!**/uv.lock"
        ]
    },
    "plugins": [
        { "path": "./tools/biome/no-arity-sibling.grit", "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"] },
        {
            "path": "./tools/biome/no-await-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        },
        {
            "path": "./tools/biome/no-barrel-reexport.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        },
        {
            "path": "./tools/biome/no-blanket-catchall.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        },
        { "path": "./tools/biome/no-domain-throw.grit", "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"] },
        {
            "path": "./tools/biome/no-mutable-accumulation.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        },
        {
            "path": "./tools/biome/no-nullable-return.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        },
        { "path": "./tools/biome/no-rename-wrapper.grit", "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"] },
        { "path": "./tools/biome/no-run-in-domain.grit", "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"] },
        {
            "path": "./tools/biome/no-standalone-brand.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        },
        {
            "path": "./tools/biome/no-stdlib-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.ts", "!**/*.test.ts", "!**/*.bench.ts"]
        }
    ],
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 150
    },
    "linter": {
        "enabled": true,
        "domains": {
            "project": "recommended",
            "test": "recommended",
            "types": "recommended"
        },
        "rules": {
            "preset": "recommended",
            "complexity": {
                "useLiteralKeys": "off"
            },
            "suspicious": {
                "noExplicitAny": "error",
                "noShadowRestrictedNames": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}

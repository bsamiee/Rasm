{
  "bash": {
    "command": "bash-language-server",
    "args": ["start"],
    "extensionToLanguage": {
      ".sh": "shellscript",
      ".bash": "shellscript"
    },
    "settings": {
      "bashIde": {
        "shellcheckPath": "shellcheck",
        "shfmt": {
          "path": "shfmt"
        }
      }
    }
  }
}

<?xml version="1.0" encoding="utf-8"?>
<!-- nuget.org is the only restore/audit source; repo-local clears block user-level source drift and lock-file contentHash pins package payloads. -->
<configuration>
    <packageSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    </packageSources>
    <packageSourceMapping>
        <clear />
    </packageSourceMapping>
    <auditSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    </auditSources>
</configuration>

<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Shell-private ALC resident for the rebuilt runtime bridge: pipe server, StreamJsonRpc target, idle-pump UI marshal, collectible cargo gate.</Description>
        <RootNamespace>Rasm.Bridge.Shell</RootNamespace>
        <!-- tools/rhino-bridge-next sits outside the path-derived classification roots; posture is
             declared explicitly. The shell is NOT a plugin project (the stub owns the .rhp): it is
             loaded by the stub's ShellLoadContext from the deploy dir, so it needs RhinoCommon via
             the host HintPath (Private=false) and ships its full restored closure as the deploy
             set (EnableDynamicLoading drives deps.json + copy-local for the resolver). -->
        <IsRhinoCommonAwareProject>true</IsRhinoCommonAwareProject>
        <UseWorkspaceLibraries>false</UseWorkspaceLibraries>
        <CspScope>Boundary</CspScope>
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
        <InformationalVersion>0.1.0-shell</InformationalVersion>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="StreamJsonRpc" />
        <ProjectReference Include="../Rasm.Bridge.Contract/Rasm.Bridge.Contract.csproj" />
    </ItemGroup>
</Project>

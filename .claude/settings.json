{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-env.sh",
                        "timeout": 10
                    }
                ]
            }
        ]
    },
    "effortLevel": "high",
    "claudeMdExcludes": [
        "**/.cache/**/CLAUDE.md",
        "**/node_modules/**/CLAUDE.md",
        "**/bin/**/CLAUDE.md",
        "**/obj/**/CLAUDE.md",
        "**/.artifacts/**/CLAUDE.md"
    ],
    "permissions": {
        "allow": [
            "Bash(git *)",
            "Bash(node *)",
            "Bash(uv *)",
            "Bash(rg *)",
            "Bash(fd *)",
            "Bash(ls *)",
            "Bash(tree *)",
            "Bash(loc *)",
            "Bash(cat *)",
            "Bash(mkdir *)",
            "Bash(mv *)"
        ],
        "deny": [],
        "defaultMode": "bypassPermissions"
    },
    "skipDangerousModePermissionPrompt": true
}

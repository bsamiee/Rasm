<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <AssemblyName>Rasm.Grasshopper</AssemblyName>
        <RootNamespace>Grasshopper</RootNamespace>
        <Title>Rasm.Grasshopper</Title>
        <Description>GH2 component infrastructure for Rasm: typed parameter bindings (GeometryParameterKind), bridge plumbing, and analysis-component base.</Description>
        <IsGrasshopperAwareProject>true</IsGrasshopperAwareProject>
        <SkipBoundaryExemptionContracts>true</SkipBoundaryExemptionContracts>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../Rasm/Rasm.csproj" />
    </ItemGroup>
</Project>

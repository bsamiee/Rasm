<Project>
    <PropertyGroup Label="Central Package Management">
        <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
        <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
        <CentralPackageVersionOverrideEnabled>false</CentralPackageVersionOverrideEnabled>
    </PropertyGroup>

    <ItemGroup Label="Rhino UI Compile Surface">
        <PackageVersion Include="System.Drawing.Common" Version="10.0.9" />
        <PackageVersion Include="System.Configuration.ConfigurationManager" Version="10.0.9" />
        <PackageVersion Include="System.IO.Packaging" Version="10.0.9" />
    </ItemGroup>

    <ItemGroup Label="Functional Core">
        <PackageVersion Include="JetBrains.Annotations" Version="2026.2.0" />
        <PackageVersion Include="LanguageExt.Core" Version="5.0.0-beta-77" />
        <PackageVersion Include="Thinktecture.Runtime.Extensions" Version="10.4.0" />
        <PackageVersion Include="Thinktecture.Runtime.Extensions.Json" Version="10.4.0" />
        <PackageVersion Include="Thinktecture.Runtime.Extensions.MessagePack" Version="10.4.0" />
    </ItemGroup>

    <ItemGroup Label="Numerics">
        <!-- Pure-managed AnyCPU, zero deps. -->
        <PackageVersion Include="ExtendedNumerics.BigRational" Version="3000.0.2.132" />
        <!-- net10.0-first, zero deps. -->
        <PackageVersion Include="TYoshimura.DoubleDouble" Version="5.0.8" />
        <!-- CC0-1.0 public domain, pure-managed AnyCPU (netstandard1.0 binds forward), zero deps. -->
        <PackageVersion Include="PeterO.Numbers" Version="1.8.2" />
        <PackageVersion Include="CSparse" Version="4.4.0" />
        <PackageVersion Include="FParsec" Version="2.0.0-beta2" />
        <PackageVersion Include="FSharp.Core" Version="11.0.100" />
        <PackageVersion Include="MathNet.Numerics" Version="6.0.0-beta2" />
        <PackageVersion Include="MathNet.Numerics.FSharp" Version="6.0.0-beta2" />
        <!-- Version-matched to the 6.0.0-beta2 MathNet core line. -->
        <PackageVersion Include="MathNet.Numerics.Providers.MKL" Version="6.0.0-beta2" />
        <PackageVersion Include="MathNet.Numerics.Providers.OpenBLAS" Version="6.0.0-beta2" />
        <PackageVersion Include="MathNet.Symbolics" Version="0.25.0" />
    </ItemGroup>

    <ItemGroup Label="Geometry Kernel">
        <!-- MIT, netstandard2.0 binds forward, zero deps. -->
        <PackageVersion Include="GShark" Version="2.3.1" />
        <!-- MIT, net8.0, zero deps, AnyCPU. -->
        <PackageVersion Include="Supercluster.KDTree.Net" Version="1.0.22" />
        <!-- MIT, netstandard2.0 binds forward, zero deps, AnyCPU. -->
        <PackageVersion Include="LibTessDotNet" Version="1.1.15" />
        <PackageVersion Include="Clipper2" Version="2.0.0" />
        <PackageVersion Include="CavalierContours" Version="1.0.0" />
        <PackageVersion Include="SharpVoronoiLib" Version="1.2.0" />
        <PackageVersion Include="MIConvexHull" Version="1.1.19.1019" />
        <PackageVersion Include="Triangle" Version="0.0.6-Beta3" />
        <PackageVersion Include="geometry3Sharp" Version="1.0.324" />
    </ItemGroup>

    <ItemGroup Label="App Host">
        <PackageVersion Include="FluentValidation" Version="12.1.1" />
        <PackageVersion Include="FluentValidation.DependencyInjectionExtensions" Version="12.1.1" />
        <PackageVersion Include="Microsoft.Extensions.Caching.Hybrid" Version="10.7.0" />
        <PackageVersion Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Configuration.CommandLine" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Configuration.Json" Version="10.0.9" />
        <PackageVersion Include="Cronos" Version="0.13.0" />
        <PackageVersion Include="Microsoft.Extensions.Configuration.UserSecrets" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.DependencyInjection" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Diagnostics.HealthChecks" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Diagnostics.ResourceMonitoring" Version="10.7.0" />
        <PackageVersion Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Hosting.Systemd" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Http.Resilience" Version="10.7.0" />
        <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.ObjectPool" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Options" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Telemetry" Version="10.7.0" />
        <PackageVersion Include="Microsoft.Extensions.Telemetry.Abstractions" Version="10.7.0" />
        <PackageVersion Include="OpenTelemetry" Version="1.16.0" />
        <PackageVersion Include="OpenTelemetry.Extensions.Hosting" Version="1.16.0" />
        <!-- OTLP exporter placement is an app-root decision. -->
        <PackageVersion Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.16.0" />
        <PackageVersion Include="OpenTelemetry.Instrumentation.Http" Version="1.16.0" />
        <PackageVersion Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.1" />
        <PackageVersion Include="Polly.Core" Version="8.7.0" />
        <PackageVersion Include="Polly.Extensions" Version="8.7.0" />
        <PackageVersion Include="Polly.RateLimiting" Version="8.7.0" />
        <PackageVersion Include="Scrutor" Version="7.0.0" />
        <PackageVersion Include="Serilog" Version="4.3.1" />
        <!-- Serilog is a provider behind the MEL seam; OTLP sink rejected (one OTLP owner). -->
        <PackageVersion Include="Serilog.Extensions.Hosting" Version="10.0.0" />
        <PackageVersion Include="Serilog.Sinks.Console" Version="6.1.1" />
        <PackageVersion Include="Serilog.Sinks.File" Version="7.0.0" />
        <PackageVersion Include="System.Threading.Tasks.Dataflow" Version="10.0.9" />
        <PackageVersion Include="Velopack" Version="1.2.0" />
        <PackageVersion Include="NodaTime" Version="3.3.2" />
        <!-- Adapters ride the NodaTime 3.3.2 line. -->
        <PackageVersion Include="NodaTime.Serialization.Protobuf" Version="2.0.2" />
        <PackageVersion Include="NodaTime.Serialization.SystemTextJson" Version="1.4.0" />
        <PackageVersion Include="Pyroscope.OpenTelemetry" Version="0.5.0" />
        <PackageVersion Include="ModelContextProtocol" Version="1.4.0" />
        <PackageVersion Include="ModelContextProtocol.Core" Version="1.4.0" />
        <PackageVersion Include="ModelContextProtocol.AspNetCore" Version="1.4.0" />
        <PackageVersion Include="Wasmtime" Version="44.0.0" />
        <PackageVersion Include="OPCFoundation.NetStandard.Opc.Ua" Version="1.5.378.152" />
        <PackageVersion Include="OPCFoundation.NetStandard.Opc.Ua.PubSub" Version="1.5.378.152" />
        <PackageVersion Include="MQTTnet" Version="5.1.0.1559" />
        <!-- App-root-pinned host transports. -->
        <PackageVersion Include="FluentModbus" Version="5.3.2" />
        <PackageVersion Include="System.IO.Ports" Version="10.0.9" />
        <!-- Rides the 10.7.0 line with the admitted Abstractions surface. -->
        <PackageVersion Include="Microsoft.Extensions.AI" Version="10.7.0" />
        <!-- Host-neutral, no ASP.NET pipeline coupling. -->
        <PackageVersion Include="OpenIddict.Client" Version="7.5.0" />
        <PackageVersion Include="Microsoft.AspNetCore.Authorization" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.ServiceDiscovery" Version="10.7.0" />
        <PackageVersion Include="OpenFeature" Version="2.14.0" />
        <!-- Host-neutral validation leg. -->
        <PackageVersion Include="Microsoft.IdentityModel.JsonWebTokens" Version="8.19.1" />
        <PackageVersion Include="Microsoft.IdentityModel.Tokens" Version="8.19.1" />
        <PackageVersion Include="Microsoft.IdentityModel.Protocols.OpenIdConnect" Version="8.19.1" />
        <!-- Offline trust-root verification; SemVer-2.0 range grammar. -->
        <PackageVersion Include="Sigstore" Version="0.5.0" />
        <PackageVersion Include="NuGet.Versioning" Version="7.6.0" />
        <!-- Vocab data embedded offline (air-gapped pricing). -->
        <PackageVersion Include="Microsoft.ML.Tokenizers" Version="2.0.0" />
        <PackageVersion Include="Microsoft.ML.Tokenizers.Data.O200kBase" Version="2.0.0" />
        <PackageVersion Include="Microsoft.ML.Tokenizers.Data.Cl100kBase" Version="2.0.0" />
        <!-- Xabaril, Apache-2.0, net8.0 binds forward under net10. -->
        <PackageVersion Include="AspNetCore.HealthChecks.NpgSql" Version="9.0.0" />
        <PackageVersion Include="AspNetCore.HealthChecks.Redis" Version="9.0.0" />
        <PackageVersion Include="AspNetCore.HealthChecks.System" Version="9.0.0" />
        <PackageVersion Include="AspNetCore.HealthChecks.Uris" Version="9.0.0" />
        <PackageVersion Include="AspNetCore.HealthChecks.Kafka" Version="9.0.0" />
        <!-- Matched 2.80.0 gRPC line; shared with Compute wire-plane. -->
        <PackageVersion Include="Grpc.AspNetCore" Version="2.80.0" />
        <PackageVersion Include="Grpc.AspNetCore.HealthChecks" Version="2.80.0" />
        <PackageVersion Include="Grpc.AspNetCore.Web" Version="2.80.0" />
        <PackageVersion Include="Grpc.Core.Api" Version="2.80.0" />
        <!-- Shared RFC 6902 shape with Persistence snapshot deltas. -->
        <PackageVersion Include="Microsoft.AspNetCore.JsonPatch.SystemTextJson" Version="10.0.9" />
        <!-- Beta line (2.0.9). -->
        <PackageVersion Include="System.CommandLine" Version="2.0.9" />
    </ItemGroup>

    <ItemGroup Label="Persistence">
        <!-- Arrow + Flight ride 23.0.0; ADBC on its own 0.x line. -->
        <PackageVersion Include="Apache.Arrow" Version="23.0.0" />
        <PackageVersion Include="Apache.Arrow.Flight" Version="23.0.0" />
        <PackageVersion Include="Apache.Arrow.Adbc" Version="0.23.0" />
        <!-- Rides 23.0.0 Arrow line; pure-managed (no native RID asset); transitives K4os.Compression.LZ4.Streams + ZstdSharp.Port floor-pinned. -->
        <PackageVersion Include="Apache.Arrow.Compression" Version="23.0.0" />
        <PackageVersion Include="FastCDC.Net" Version="1.0.1" />
        <!-- osx-arm64 native dylib ships in-package (runtimes/osx-arm64/native); Apache-2.0; rides Apache.Arrow 23.0.0; modern net8.0 RID-asset resolution, no .targets RID gate. -->
        <PackageVersion Include="ParquetSharp" Version="23.0.0.2" />
        <!-- Pure-managed AnyCPU net10.0, Apache-2.0; transitive SqlParserCS floor-pinned. -->
        <PackageVersion Include="FlowtideDotNet.Substrait" Version="0.15.0" />
        <PackageVersion Include="DuckDB.NET.Data.Full" Version="1.5.3" />
        <PackageVersion Include="Ara3D.BimOpenSchema" Version="1.0.1" />
        <PackageVersion Include="Ara3D.BimOpenSchema.IO" Version="1.0.1" />
        <PackageVersion Include="Ara3D.SDK" Version="1.4.2" />
        <PackageVersion Include="ClosedXML" Version="0.105.0" />
        <PackageVersion Include="Parquet.Net" Version="6.0.3" />
        <PackageVersion Include="PollinationSDK" Version="1.10.0" />
        <PackageVersion Include="AWSSDK.S3" Version="4.0.25.3" />
        <PackageVersion Include="Azure.Storage.Blobs" Version="12.29.1" />
        <PackageVersion Include="Google.Cloud.Storage.V1" Version="4.15.0" />
        <!-- AWS v4 shares AWSSDK.Core 4.x with AWSSDK.S3 (no diamond); Azure rides Azure.Core; Google is pure-managed Grpc.Net.Client. -->
        <PackageVersion Include="AWSSDK.KeyManagementService" Version="4.0.12.9" />
        <PackageVersion Include="Azure.Security.KeyVault.Keys" Version="4.10.0" />
        <PackageVersion Include="Google.Cloud.Kms.V1" Version="3.24.0" />
        <!-- Confluent.Kafka bundles librdkafka.redist (osx-arm64 native verified); CloudEvents on 2.8.0. -->
        <PackageVersion Include="Confluent.Kafka" Version="2.14.2" />
        <PackageVersion Include="CloudNative.CloudEvents" Version="2.8.0" />
        <PackageVersion Include="CloudNative.CloudEvents.Kafka" Version="2.8.0" />
        <PackageVersion Include="CloudNative.CloudEvents.SystemTextJson" Version="2.8.0" />
        <PackageVersion Include="StackExchange.Redis" Version="3.0.7" />
        <PackageVersion Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="10.0.9" />
        <!-- Pure-managed AnyCPU net6.0; transitive floors Apache.Avro / protobuf-net.* / NJsonSchema.* pinned; Confluent.SchemaRegistry co-pin drives the serde registry leg. -->
        <PackageVersion Include="Chr.Avro" Version="10.13.1" />
        <PackageVersion Include="Chr.Avro.Binary" Version="10.13.1" />
        <PackageVersion Include="Chr.Avro.Confluent" Version="10.13.1" />
        <!-- Pure-managed AnyCPU net8.0; ride the 2.14.2 Confluent line in lockstep. -->
        <PackageVersion Include="Confluent.SchemaRegistry" Version="2.14.2" />
        <PackageVersion Include="Confluent.SchemaRegistry.Serdes.Avro" Version="2.14.2" />
        <PackageVersion Include="Confluent.SchemaRegistry.Serdes.Protobuf" Version="2.14.2" />
        <PackageVersion Include="Confluent.SchemaRegistry.Serdes.Json" Version="2.14.2" />
        <!-- Zero deps, AnyCPU. -->
        <PackageVersion Include="System.Formats.Cbor" Version="10.0.9" />
        <!-- Meta-package fans out to the 2.8.2 sub-clients (floor-pinned); pure-managed AnyCPU net8.0, Apache-2.0. -->
        <PackageVersion Include="NATS.Net" Version="2.8.2" />
        <!-- Pure-managed AnyCPU net8.0, Apache-2.0 OR MPL-2.0. -->
        <PackageVersion Include="RabbitMQ.Client" Version="7.2.1" />
        <!-- lib/net10.0 ships, pure-managed AnyCPU. -->
        <PackageVersion Include="DotPulsar" Version="5.3.1" />
        <!-- lib/net10.0, MIT. -->
        <PackageVersion Include="ClickHouse.Driver" Version="1.2.0" />
        <!-- netstandard2.0, Apache-2.0. -->
        <PackageVersion Include="ScyllaDBCSharpDriver" Version="3.22.0.3" />
        <!-- Ships runtimes/osx-arm64/native/librocksdb.dylib + lib/net10.0; BSD-2-Clause. -->
        <PackageVersion Include="rocksdb" Version="10.10.1.1747" />
        <!-- Ships runtimes/osx-arm64/native/lmdb.dylib + lib/net10.0, zero managed deps; OpenLDAP-2.8. -->
        <PackageVersion Include="LightningDB" Version="0.21.0" />
        <!-- Pure-managed net8.0, Apache-2.0. -->
        <PackageVersion Include="Minio" Version="7.0.0" />
        <!-- Ships osx-arm64 delta_kernel/delta_rs dylibs; MIT. -->
        <PackageVersion Include="DeltaLake.Net" Version="0.32.0" />
        <!-- Both lib/net8.0 AnyCPU, no native lib; Apache-2.0; on the 0.23.0 ADBC line. -->
        <PackageVersion Include="Apache.Arrow.Adbc.Drivers.Apache" Version="0.23.0" />
        <PackageVersion Include="Apache.Arrow.Adbc.Drivers.BigQuery" Version="0.23.0" />
        <!-- Pure-managed AnyCPU (polygon ops via the admitted NetTopologySuite); Apache-2.0; dual-consumer central pin (Persistence + Bim). -->
        <PackageVersion Include="pocketken.H3" Version="4.0.0" />
        <!-- Pure-managed AnyCPU gRPC net6.0; Apache-2.0. -->
        <PackageVersion Include="Qdrant.Client" Version="1.18.1" />
        <!-- Pure-managed AnyCPU net6.0, zero deps; MIT. -->
        <PackageVersion Include="Sylvan.Data.Excel" Version="0.5.6" />
        <PackageVersion Include="EFCore.NamingConventions" Version="10.0.1" />
        <PackageVersion Include="K4os.Compression.LZ4" Version="1.3.8" />
        <PackageVersion Include="linq2db.EntityFrameworkCore" Version="10.4.0" />
        <PackageVersion Include="MessagePack" Version="3.1.7" />
        <PackageVersion Include="MessagePackAnalyzer" Version="3.1.7" />
        <PackageVersion Include="Microsoft.Data.Sqlite" Version="10.0.9" />
        <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.9" />
        <PackageVersion Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Compliance.Redaction" Version="10.7.0" />
        <PackageVersion Include="Npgsql" Version="10.0.3" />
        <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.2" />
        <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL.NetTopologySuite" Version="10.0.2" />
        <PackageVersion Include="Npgsql.EntityFrameworkCore.PostgreSQL.NodaTime" Version="10.0.2" />
        <PackageVersion Include="Npgsql.NetTopologySuite" Version="10.0.3" />
        <!-- Dual-consumer central pin (Persistence PostGIS + Bim geospatial). -->
        <PackageVersion Include="NetTopologySuite.IO.GeoJSON4STJ" Version="4.0.0" />
        <PackageVersion Include="NetTopologySuite.IO.GeoPackage" Version="2.0.0" />
        <PackageVersion Include="Npgsql.OpenTelemetry" Version="10.0.3" />
        <PackageVersion Include="Pgvector" Version="0.3.2" />
        <PackageVersion Include="Pgvector.EntityFrameworkCore" Version="0.3.0" />
        <PackageVersion Include="Sep" Version="0.15.0" />
        <PackageVersion Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
        <PackageVersion Include="System.IO.Hashing" Version="10.0.9" />
        <!-- EF companion pairs with the 10.2.0 core generator; the whole family rides one version line. -->
        <PackageVersion Include="Thinktecture.Runtime.Extensions.EntityFrameworkCore10" Version="10.4.0" />
        <!-- Heavy transitive closure (Microsoft.Data.Sqlite native e_sqlite3, GraphQL.Client, STJ); never referenced by an in-Rhino plugin assembly; Speckle.Sdk ILRepacks its closure. -->
        <PackageVersion Include="Speckle.Sdk" Version="2026.6.0" />
        <PackageVersion Include="Speckle.Objects" Version="2026.6.0" />
    </ItemGroup>

    <ItemGroup Label="Compute">
        <PackageVersion Include="CommunityToolkit.HighPerformance" Version="8.4.2" />
        <PackageVersion Include="Google.Protobuf" Version="3.35.1" />
        <PackageVersion Include="Grpc.Net.Client" Version="2.80.0" />
        <PackageVersion Include="Grpc.Net.Client.Web" Version="2.80.0" />
        <PackageVersion Include="Grpc.Net.Common" Version="2.80.0" />
        <PackageVersion Include="Grpc.Tools" Version="2.81.1" />
        <PackageVersion Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
        <PackageVersion Include="Microsoft.ML.OnnxRuntime" Version="1.27.0" />
        <PackageVersion Include="Microsoft.ML.OnnxRuntime.Extensions" Version="0.14.0" />
        <PackageVersion Include="Microsoft.ML.OnnxRuntimeGenAI" Version="0.14.1" />
        <!-- Core + Gpu ride 1.27.0; DirectML NuGet ceiling is 1.24.4; osx-arm64 never loads either; Extensions 0.14.0 / GenAI 0.14.1 HOLD. -->
        <PackageVersion Include="Microsoft.ML.OnnxRuntime.Gpu" Version="1.27.0" />
        <PackageVersion Include="Microsoft.ML.OnnxRuntime.DirectML" Version="1.24.4" />
        <PackageVersion Include="Microsoft.Extensions.AI.Abstractions" Version="10.7.0" />
        <PackageVersion Include="System.Numerics.Tensors" Version="10.0.9" />
        <!-- 5.75.0; one central pin, in-folder reference per consumer (Compute, Bim, Fabrication, Materials, AppUi); never a cross-strata downward reference. -->
        <PackageVersion Include="UnitsNet" Version="5.75.0" />
        <!-- Meta-package only — the per-RID native runtimes (incl. osx-arm64) resolve transitively. -->
        <PackageVersion Include="Google.OrTools" Version="9.15.6755" />
        <!-- Pure-managed AnyCPU net6.0, zero deps, MIT. -->
        <PackageVersion Include="GeneticSharp" Version="3.1.4" />
        <!-- MIT, net8.0; libtorch-cpu fans out to libtorch-cpu-osx-arm64 native dylib (one logical admission); SkiaSharp/Google.Protobuf transitives ride existing rows; SharpZipLib + System.Memory floors pinned. -->
        <PackageVersion Include="TorchSharp" Version="0.107.0" />
        <PackageVersion Include="libtorch-cpu" Version="2.10.0" />
        <PackageVersion Include="FEALiTE2D" Version="1.1.2" />
        <PackageVersion Include="FEALiTE2D.Plotting" Version="1.1.2" />
        <PackageVersion Include="netDxf.netstandard" Version="3.0.1" />
        <PackageVersion Include="BriefFiniteElement.Net" Version="2.1.2" />
        <PackageVersion Include="BriefFiniteElementNet.CustomElements" Version="2.1.2" />
        <PackageVersion Include="BriefFiniteElementNet.Common" Version="2.1.2" />
    </ItemGroup>

    <!-- Interchange: glTF codec pins owned by Compute and co-consumed by Bim (the Bim<->Compute SharpGLTF/meshopt
         leg-split seam). The IFC semantic graph is owned by Rasm.Bim (GeometryGymIFC_Core, in the Bim group);
         parametric IFC->mesh runs out-of-process via an IfcOpenShell companion node (PyPI, libs/python/compute),
         never a NuGet pin. -->
    <ItemGroup Label="Interchange">
        <!-- 1.0.6 line; dual-consumer central pin (Compute owner + Bim co-consumer). -->
        <PackageVersion Include="SharpGLTF.Core" Version="1.0.6" />
        <PackageVersion Include="SharpGLTF.Runtime" Version="1.0.6" />
        <PackageVersion Include="SharpGLTF.Toolkit" Version="1.0.6" />
        <!-- 1.0.6 line; OneOf transitive pinned explicitly; dual-consumer (Bim author + Compute compose). -->
        <PackageVersion Include="SharpGLTF.Ext.3DTiles" Version="1.0.6" />
        <PackageVersion Include="OneOf" Version="3.0.271" />
        <!-- Openize.Drako: pure-managed; commercial Openize license accepted; Bim EXPORT_RAIL, outside-Rhino. -->
        <PackageVersion Include="Openize.Drako" Version="26.2.0" />
        <!-- MIT; universal osx-arm64+x64; net10-only (firebreaks it out of any net48 in-Rhino plugin ALC); Compute EXPORT_RAIL outside-Rhino; dual-consumer central pin. -->
        <PackageVersion Include="Alimer.Bindings.MeshOptimizer" Version="1.2.1" />
    </ItemGroup>

    <!-- Bim: AEC-domain interchange + georeferencing + review pins the Rasm.Bim folder owns directly.
         Native assets ship only for USD, OpenStudio, and GDAL via their osx-arm64 runtimes; everything else is pure-managed AnyCPU. -->
    <ItemGroup Label="Bim">
        <!-- Pure-managed IL-only AnyCPU, MIT. -->
        <PackageVersion Include="GeometryGymIFC_Core" Version="25.7.30" />
        <PackageVersion Include="StructuralAnalysisFormat" Version="1.7.3" />
        <PackageVersion Include="BrickSchema.Net" Version="1.3.30" />
        <PackageVersion Include="dotbim" Version="1.2.0" />
        <PackageVersion Include="HoneybeeSchema" Version="2.102.0" />
        <PackageVersion Include="DragonflySchema" Version="2.201.0" />
        <PackageVersion Include="NREL.OpenStudio.macOS-arm64" Version="3.11.0" />
        <PackageVersion Include="Xbim.CobieExpress" Version="6.0.172" />
        <PackageVersion Include="Xbim.IO.CobieExpress" Version="6.0.172" />
        <PackageVersion Include="Xbim.CobieExpress.Exchanger" Version="6.0.172" />
        <PackageVersion Include="Xbim.Common" Version="6.0.587" />
        <PackageVersion Include="Xbim.Ifc" Version="6.0.587" />
        <PackageVersion Include="Xbim.Ifc4" Version="6.0.587" />
        <PackageVersion Include="Xbim.IO.Table" Version="6.0.172" />
        <PackageVersion Include="VividOrange.ILoads" Version="0.1.0" />
        <PackageVersion Include="VividOrange.Loads" Version="0.1.0" />
        <PackageVersion Include="VividOrange.ICases" Version="0.1.0" />
        <PackageVersion Include="VividOrange.Cases" Version="0.1.0" />
        <PackageVersion Include="VividOrange.IStages" Version="0.1.0" />
        <PackageVersion Include="VividOrange.Stages" Version="0.1.0" />
        <PackageVersion Include="VividOrange.Countries" Version="0.1.0" />
        <!-- Ships a real osx-arm64 native runtime (libUsdCs/libusd_* + Pixar plugin tree); requireLicenseAcceptance. -->
        <PackageVersion Include="UniversalSceneDescription" Version="7.3.4" />
        <!-- Apache-2.0 (per-component), single BCL transitive. -->
        <PackageVersion Include="Ply.Net" Version="5.6.2" />
        <!-- Xids CDDL-1.0 (OSI); ids-lib MIT pure-managed net10.0 and the transitive floor of Xids (>=1.0.112). -->
        <PackageVersion Include="Xbim.InformationSpecifications" Version="1.0.24" />
        <PackageVersion Include="ids-lib" Version="1.0.121" />
        <!-- Apache-2.0, pure-managed; Json.Net + RecursiveDataAnnotationsValidation floor-pinned. -->
        <PackageVersion Include="Smino.Bcf.Toolkit" Version="3.2.0" />
        <!-- BSD-3-Clause; Bim-owned pin transitively consumed by AppUi Mapsui. -->
        <PackageVersion Include="NetTopologySuite" Version="2.6.0" />
        <!-- BSD-3-Clause; transitive NetTopologySuite.Features floor pinned. -->
        <PackageVersion Include="NetTopologySuite.IO.Esri.Shapefile" Version="1.2.0" />
        <!-- MIT; native runtime is RID-keyed osx-arm64; admit core+runtime as one pair. -->
        <PackageVersion Include="MaxRev.Gdal.Core" Version="3.13.1.534" />
        <PackageVersion Include="MaxRev.Gdal.MacosRuntime.Minimal.arm64" Version="3.13.1.534" />
        <!-- Pure-managed (2.1.0). -->

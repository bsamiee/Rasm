{
    "disabledMcpjsonServers": ["React Aria", "tailwindcss-server"],
    "enabledMcpjsonServers": ["playwright-test"],
    "outputStyle": "functional-purist",
    "permissions": {
        "allow": [
            "Read",
            "Write",
            "Edit",
            "Glob",
            "Grep",
            "Task",
            "TaskCreate",
            "TaskUpdate",
            "TaskList",
            "TaskGet",
            "NotebookEdit",
            "WebSearch",
            "WebFetch",
            "Skill",
            "SlashCommand",
            "Bash(curl:*)",
            "Bash(pnpm:*)",
            "Bash(nx:*)",
            "Bash(git:*)",
            "Bash(gh:*)",
            "Bash(node:*)",
            "Bash(ty:*)",
            "Bash(uv:*)",
            "mcp__playwright-test__*",
            "mcp__playwright__browser_*"
        ],
        "deny": [],
        "ask": []
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-env.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-spec.sh",
                        "timeout": 10
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {}
}

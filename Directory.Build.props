<Project>
    <PropertyGroup Label="Workspace Roots">
        <SolutionDir Condition="'$(SolutionDir)' == '' or '$(SolutionDir)' == '*Undefined*'">$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)'))</SolutionDir>
        <SolutionName Condition="'$(SolutionName)' == '' or '$(SolutionName)' == '*Undefined*'">Workspace</SolutionName>
        <CSharpLibsRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', 'libs', 'csharp'))</CSharpLibsRoot>
        <RasmGrasshopperRoot>$([MSBuild]::NormalizeDirectory('$(CSharpLibsRoot)', 'Rasm.Grasshopper'))</RasmGrasshopperRoot>
        <RasmRhinoRoot>$([MSBuild]::NormalizeDirectory('$(CSharpLibsRoot)', 'Rasm.Rhino'))</RasmRhinoRoot>
        <RhinoAppsRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', 'apps', 'rhino'))</RhinoAppsRoot>
        <RhinoBridgeRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', 'tools', 'rhino-bridge'))</RhinoBridgeRoot>
        <YakPackagesRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', 'tools', 'yak'))</YakPackagesRoot>
        <YakStageRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', '.artifacts', 'rhino'))</YakStageRoot>
        <TestsRoot>$([MSBuild]::NormalizeDirectory('$(MSBuildThisFileDirectory)', 'tests', 'csharp'))</TestsRoot>
        <TestsArchitectureRoot>$([MSBuild]::NormalizeDirectory('$(TestsRoot)', '_architecture'))</TestsArchitectureRoot>
        <TestKitRoot>$([MSBuild]::NormalizeDirectory('$(TestsRoot)', '_testkit'))</TestKitRoot>
        <TestScenarioKitRoot>$([MSBuild]::NormalizeDirectory('$(TestsRoot)', '_scenariokit'))</TestScenarioKitRoot>
        <TestsLibsRoot>$([MSBuild]::NormalizeDirectory('$(TestsRoot)', 'libs'))</TestsLibsRoot>
        <TestsRasmAppUiRoot>$([MSBuild]::NormalizeDirectory('$(TestsLibsRoot)', 'Rasm.AppUi'))</TestsRasmAppUiRoot>
        <TestsRasmComputeRoot>$([MSBuild]::NormalizeDirectory('$(TestsLibsRoot)', 'Rasm.Compute'))</TestsRasmComputeRoot>
        <TestsRasmRoot>$([MSBuild]::NormalizeDirectory('$(TestsLibsRoot)', 'Rasm'))</TestsRasmRoot>
        <TestsRasmGrasshopperRoot>$([MSBuild]::NormalizeDirectory('$(TestsLibsRoot)', 'Rasm.Grasshopper'))</TestsRasmGrasshopperRoot>
        <TestsRasmRhinoRoot>$([MSBuild]::NormalizeDirectory('$(TestsLibsRoot)', 'Rasm.Rhino'))</TestsRasmRhinoRoot>
        <TestsScenariosRoot>$([MSBuild]::NormalizeDirectory('$(TestsRoot)', 'scenarios'))</TestsScenariosRoot>
    </PropertyGroup>

    <PropertyGroup Label="Project Classifiers">
        <NormalizedProjectDirectory>$([MSBuild]::NormalizeDirectory('$(MSBuildProjectDirectory)'))</NormalizedProjectDirectory>
        <IsRhinoBridgeProject Condition="'$(IsRhinoBridgeProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoBridgeRoot)'))">true</IsRhinoBridgeProject>
        <IsRhinoBridgeCargoProject Condition="'$(IsRhinoBridgeCargoProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoBridgeRoot)Cargo/'))">true</IsRhinoBridgeCargoProject>
        <IsRhinoBridgeContractProject Condition="'$(IsRhinoBridgeContractProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoBridgeRoot)Contract/'))">true</IsRhinoBridgeContractProject>
        <IsRhinoBridgeShellProject Condition="'$(IsRhinoBridgeShellProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoBridgeRoot)Shell/'))">true</IsRhinoBridgeShellProject>
        <IsRhinoBridgeStubProject Condition="'$(IsRhinoBridgeStubProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoBridgeRoot)Stub/'))">true</IsRhinoBridgeStubProject>
        <IsTestKitProject Condition="'$(IsTestKitProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestKitRoot)'))">true</IsTestKitProject>
        <IsScenarioKitProject Condition="'$(IsScenarioKitProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestScenarioKitRoot)'))">true</IsScenarioKitProject>
        <IsBenchmarkProject Condition="'$(IsBenchmarkProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRoot)_benchmarks/'))">true</IsBenchmarkProject>
        <IsTestProject Condition="'$(IsTestProject)' == '' and '$(IsTestKitProject)' != 'true' and '$(IsScenarioKitProject)' != 'true' and '$(IsBenchmarkProject)' != 'true' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRoot)'))">true</IsTestProject>
        <HostReferencePrivate Condition="'$(IsTestProject)' == 'true'">true</HostReferencePrivate>
        <HostReferencePrivate Condition="'$(HostReferencePrivate)' == ''">false</HostReferencePrivate>
        <IsRhinoPluginProject Condition="'$(IsRhinoPluginProject)' == '' and ($([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoAppsRoot)')) or '$(IsRhinoBridgeStubProject)' == 'true')">true</IsRhinoPluginProject>
        <IsGrasshopperPluginProject Condition="'$(IsGrasshopperPluginProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(MSBuildThisFileDirectory)apps/grasshopper/'))">true</IsGrasshopperPluginProject>
        <IsAppHostProject Condition="'$(IsAppHostProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CSharpLibsRoot)Rasm.AppHost/'))">true</IsAppHostProject>
        <IsAppUiProject Condition="'$(IsAppUiProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CSharpLibsRoot)Rasm.AppUi/'))">true</IsAppUiProject>
        <IsComputeProject Condition="'$(IsComputeProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CSharpLibsRoot)Rasm.Compute/'))">true</IsComputeProject>
        <IsPersistenceProject Condition="'$(IsPersistenceProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CSharpLibsRoot)Rasm.Persistence/'))">true</IsPersistenceProject>
        <IsGrasshopperAwareProject Condition="'$(IsGrasshopperAwareProject)' == '' and ($([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RasmGrasshopperRoot)')) or '$(IsRhinoBridgeCargoProject)' == 'true' or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmGrasshopperRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsScenariosRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsArchitectureRoot)')))">true</IsGrasshopperAwareProject>
        <!-- App-package tests stay out of Rhino host-reference inheritance. -->
        <IsRhinoCommonAwareProject Condition="'$(IsRhinoCommonAwareProject)' == '' and ($([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CSharpLibsRoot)Rasm/')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RasmGrasshopperRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RasmRhinoRoot)')) or '$(IsRhinoBridgeShellProject)' == 'true' or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestScenarioKitRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmGrasshopperRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmRhinoRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsArchitectureRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsScenariosRoot)')))">true</IsRhinoCommonAwareProject>
        <IsRhinoUiAwareProject Condition="'$(IsRhinoUiAwareProject)' == '' and ($([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RasmRhinoRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(RhinoAppsRoot)')) or '$(IsRhinoBridgeCargoProject)' == 'true' or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmRhinoRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsScenariosRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsArchitectureRoot)')))">true</IsRhinoUiAwareProject>
        <NeedsRhinoHostUiSurface Condition="'$(IsRhinoUiAwareProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true'">true</NeedsRhinoHostUiSurface>
    </PropertyGroup>

    <PropertyGroup Label="Output Routing">
        <IsCentralizedOutputProject Condition="'$(IsCentralizedOutputProject)' == '' and '$(IsRhinoBridgeProject)' != 'true' and '$(IsRhinoPluginProject)' != 'true' and '$(IsGrasshopperPluginProject)' != 'true' and '$(IsAppHostProject)' != 'true' and '$(IsAppUiProject)' != 'true'">true</IsCentralizedOutputProject>
        <CentralOutputToken Condition="'$(CentralOutputToken)' == ''">$(AssemblyName)</CentralOutputToken>
        <CentralOutputToken Condition="'$(CentralOutputToken)' == ''">$(MSBuildProjectName)</CentralOutputToken>
        <!-- Output precedence: assay ArtifactsPath (ArtifactsProjectName) wins, then the centralized .artifacts/build default, then excluded host/plugin/app projects (in-tree SDK default for sibling-DLL resolution and yak staging). -->
        <ArtifactsProjectName Condition="'$(ArtifactsPath)' != '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRoot)tools/rhino-bridge/Contract/'))">Rasm.Bridge.Contract.Tests</ArtifactsProjectName>
        <ArtifactsProjectName Condition="'$(ArtifactsPath)' != '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRoot)tools/rhino-bridge/Supervisor/'))">Rasm.Bridge.Supervisor.Tests</ArtifactsProjectName>
        <ArtifactsProjectName Condition="'$(ArtifactsPath)' != '' and '$(ArtifactsProjectName)' == '' and '$(IsCentralizedOutputProject)' == 'true'">$(CentralOutputToken)</ArtifactsProjectName>
        <BaseIntermediateOutputPath Condition="'$(ArtifactsPath)' != '' and '$(ArtifactsProjectName)' != ''">$(ArtifactsPath)/obj/$(ArtifactsProjectName)/</BaseIntermediateOutputPath>
        <BaseOutputPath Condition="'$(ArtifactsPath)' != '' and '$(ArtifactsProjectName)' != ''">$(ArtifactsPath)/bin/$(ArtifactsProjectName)/</BaseOutputPath>
        <BaseOutputPath Condition="'$(BaseOutputPath)' == '' and '$(IsCentralizedOutputProject)' == 'true'">$(MSBuildThisFileDirectory).artifacts/build/bin/$(CentralOutputToken)/</BaseOutputPath>
        <BaseIntermediateOutputPath Condition="'$(BaseIntermediateOutputPath)' == '' and '$(IsCentralizedOutputProject)' == 'true'">$(MSBuildThisFileDirectory).artifacts/build/obj/$(CentralOutputToken)/</BaseIntermediateOutputPath>
    </PropertyGroup>

    <PropertyGroup Label="Bridge Scenario Runtime" Condition="'$(IsTestProject)' == 'true'">
        <HasBridgeScenarios Condition="'$(HasBridgeScenarios)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsScenariosRoot)'))">true</HasBridgeScenarios>
        <HasBridgeScenarios Condition="'$(HasBridgeScenarios)' == ''">false</HasBridgeScenarios>
        <CopyLocalLockFileAssemblies Condition="'$(HasBridgeScenarios)' == 'true'">true</CopyLocalLockFileAssemblies>
    </PropertyGroup>

    <PropertyGroup Label="SDK Defaults">
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>14.0</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <CheckForOverflowUnderflow>true</CheckForOverflowUnderflow>
        <IsPackable Condition="'$(IsPackable)' == ''">false</IsPackable>
        <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == '' and '$(RuntimeIdentifiers)' == '' and ('$(NeedsRhinoHostUiSurface)' == 'true' or '$(IsAppUiProject)' == 'true' or '$(IsRhinoBridgeProject)' == 'true' or '$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true')">osx-arm64</RuntimeIdentifier>
        <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
        <!-- In-tree obj/bin generated sources stay excluded even when a project opts out of central output. -->
        <DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)/obj/**;$(MSBuildProjectDirectory)/bin/**</DefaultItemExcludes>
    </PropertyGroup>

    <PropertyGroup Label="Analysis Defaults">
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
        <AnalysisLevel>latest-all</AnalysisLevel>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <ErrorLog Condition="'$(CspSarifDir)' != ''">$(CspSarifDir)/$(MSBuildProjectName).sarif,version=2.1</ErrorLog>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <!-- CS9236 is Roslyn binding-cost telemetry. -->
        <NoWarn>$(NoWarn);CS1591;CA2225;CS9236</NoWarn>
        <NoWarn Condition="'$(IsRhinoUiAwareProject)' == 'true'">$(NoWarn);CA1416</NoWarn>
        <!-- CA1724: Microsoft.macOS exposes a Phase namespace colliding with the canonical ComponentUi.Phase enum. -->
        <NoWarn Condition="'$(NeedsRhinoHostUiSurface)' == 'true'">$(NoWarn);CA1724</NoWarn>
        <NeedsOnnxRuntimeLegacyRidSuppression Condition="'$(NeedsOnnxRuntimeLegacyRidSuppression)' == '' and ('$(IsComputeProject)' == 'true' or '$(IsAppUiProject)' == 'true' or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmComputeRoot)')) or $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(TestsRasmAppUiRoot)')))">true</NeedsOnnxRuntimeLegacyRidSuppression>
        <!-- Microsoft.ML.OnnxRuntime.Extensions ships legacy version-specific OSX RID assets. -->
        <NoWarn Condition="'$(NeedsOnnxRuntimeLegacyRidSuppression)' == 'true'">$(NoWarn);NETSDK1206</NoWarn>
    </PropertyGroup>

    <PropertyGroup Label="Csp Analyzer Paths">
        <LocalCSharpAnalyzerRoot>tools/cs-analyzer</LocalCSharpAnalyzerRoot>
        <LocalCSharpAnalyzerProject>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '$(LocalCSharpAnalyzerRoot)', 'Csp.Analyzer.csproj'))</LocalCSharpAnalyzerProject>
        <CspContractsProject>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '$(LocalCSharpAnalyzerRoot)', 'Contracts', 'Csp.Contracts.csproj'))</CspContractsProject>
        <IsLocalCSharpAnalyzerProject Condition="$([MSBuild]::NormalizePath('$(MSBuildProjectFullPath)')) == '$(LocalCSharpAnalyzerProject)'">true</IsLocalCSharpAnalyzerProject>
        <CsAnalyzerTestRoot>$([MSBuild]::NormalizeDirectory('$(TestsRoot)', 'tools', 'cs-analyzer'))</CsAnalyzerTestRoot>
        <IsAnalyzerTestProject Condition="'$(IsAnalyzerTestProject)' == '' and $([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CsAnalyzerTestRoot)'))">true</IsAnalyzerTestProject>
        <SkipLocalCSharpAnalyzerReference Condition="'$(SkipLocalCSharpAnalyzerReference)' == '' and ('$(IsLocalCSharpAnalyzerProject)' == 'true' or '$(IsAnalyzerTestProject)' == 'true')">true</SkipLocalCSharpAnalyzerReference>
    </PropertyGroup>

    <ItemGroup Label="Workspace Analyzer Packages" Condition="'$(IsLocalCSharpAnalyzerProject)' != 'true'">
        <PackageReference Include="Meziantou.Analyzer" PrivateAssets="all" />
        <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" PrivateAssets="all" />
    </ItemGroup>

    <!-- Missing local analyzer projects fail loudly; SkipLocalCSharpAnalyzerReference is the only opt-out. -->
    <ItemGroup Label="Workspace Source Generator And Analyzer" Condition="'$(SkipLocalCSharpAnalyzerReference)' != 'true'">
        <ProjectReference Include="$(LocalCSharpAnalyzerProject)" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>

    <!-- One Csp.Contracts identity carries BoundaryAdapter/CspExempt across host, test, and bridge projects. -->
    <ItemGroup Label="Csp Contract Reference" Condition="'$(IsRoslynComponent)' != 'true' and '$(MSBuildProjectName)' != 'Csp.Contracts'">
        <ProjectReference Include="$(CspContractsProject)" />
    </ItemGroup>

    <PropertyGroup Label="Csp Scope Defaults">
        <!-- Production libs/apps/tools declare CspScope; tests and benchmarks fall back centrally. -->
        <CspScope Condition="'$(CspScope)' == '' and ('$(IsTestProject)' == 'true' or '$(IsTestKitProject)' == 'true' or '$(IsScenarioKitProject)' == 'true')">Test</CspScope>
        <CspScope Condition="'$(CspScope)' == '' and ('$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsRhinoBridgeProject)' == 'true')">Boundary</CspScope>
        <CspScope Condition="'$(CspScope)' == '' and ('$(IsBenchmarkProject)' == 'true' or '$(IsLocalCSharpAnalyzerProject)' == 'true')">Tooling</CspScope>
    </PropertyGroup>

    <ItemGroup Label="Csp Scope Plumbing">
        <CompilerVisibleProperty Include="CspScope" />
    </ItemGroup>

    <PropertyGroup Label="Workspace Library Policy">
        <UseWorkspaceLibraries Condition="'$(UseWorkspaceLibraries)' == '' and ('$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsRhinoBridgeContractProject)' == 'true' or '$(IsRhinoBridgeShellProject)' == 'true')">false</UseWorkspaceLibraries>
        <UseWorkspaceLibraries Condition="'$(UseWorkspaceLibraries)' == ''">true</UseWorkspaceLibraries>
        <!-- Thinktecture consumers bind to one shared public JetBrains.Annotations identity. -->
        <UsesThinktecture Condition="'$(UsesThinktecture)' == '' and '$(IsLocalCSharpAnalyzerProject)' != 'true' and ('$(UseWorkspaceLibraries)' == 'true' or '$(IsRhinoBridgeContractProject)' == 'true' or '$(IsRhinoBridgeShellProject)' == 'true')">true</UsesThinktecture>
        <NeedsSystemDrawingCompilePackage Condition="'$(NeedsSystemDrawingCompilePackage)' == '' and ('$(IsRhinoUiAwareProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true')">true</NeedsSystemDrawingCompilePackage>
    </PropertyGroup>

    <PropertyGroup Label="Restore And Audit">
        <!-- Packages restore to the machine-global folder: one cross-repo copy, lockfile contentHash pins determinism. -->
        <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
        <RestoreLockedMode Condition="'$(CI)' == 'true'">true</RestoreLockedMode>
        <!-- NU1903/NU1904 escalate to restore errors under TreatWarningsAsErrors. -->
        <NuGetAudit>true</NuGetAudit>
        <NuGetAuditMode>all</NuGetAuditMode>
        <NuGetAuditLevel>high</NuGetAuditLevel>
        <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    </PropertyGroup>

    <PropertyGroup Label="RhinoWIP Host Paths">
        <RhinoWipAppPath Condition="'$(RhinoWipAppPath)' == '' and '$(RHINO_WIP_APP_PATH)' != ''">$(RHINO_WIP_APP_PATH)</RhinoWipAppPath>
        <RhinoWipAppPath Condition="'$(RhinoWipAppPath)' == ''">/Applications/RhinoWIP.app</RhinoWipAppPath>
        <RhinoWipResourcesPath>$(RhinoWipAppPath)/Contents/Frameworks/RhCore.framework/Versions/Current/Resources</RhinoWipResourcesPath>
        <RhinoCommonReferencePath>$(RhinoWipResourcesPath)/RhinoCommon.dll</RhinoCommonReferencePath>
        <RhinoUiReferencePath>$(RhinoWipResourcesPath)/Rhino.UI.dll</RhinoUiReferencePath>
        <SystemDrawingCommonReferencePath>$(RhinoWipResourcesPath)/System.Drawing.Common.dll</SystemDrawingCommonReferencePath>
        <EtoReferencePath>$(RhinoWipResourcesPath)/Eto.dll</EtoReferencePath>
        <EtoMacOSReferencePath>$(RhinoWipResourcesPath)/Eto.macOS.dll</EtoMacOSReferencePath>
        <MicrosoftMacOSReferencePath>$(RhinoWipResourcesPath)/Microsoft.macOS.dll</MicrosoftMacOSReferencePath>
        <Grasshopper2ReferencePath>$(RhinoWipResourcesPath)/ManagedPlugIns/Grasshopper2Plugin.rhp/Grasshopper2.dll</Grasshopper2ReferencePath>
        <GrasshopperIoReferencePath>$(RhinoWipResourcesPath)/ManagedPlugIns/Grasshopper2Plugin.rhp/GrasshopperIO.dll</GrasshopperIoReferencePath>
        <RhinoRuntimeCodeReferencePath>$(RhinoWipResourcesPath)/Rhino.Runtime.Code.dll</RhinoRuntimeCodeReferencePath>
        <RhinoCodePlatformReferencePath>$(RhinoWipResourcesPath)/RhinoCodePlatform.Rhino3D.dll</RhinoCodePlatformReferencePath>
        <RhinoHostAssemblyNameSet>|RhinoCommon|Rhino.UI|System.Drawing.Common|Grasshopper2|GrasshopperIO|Eto|Eto.macOS|Microsoft.macOS|Rhino.Runtime.Code|RhinoCodePlatform.Rhino3D|</RhinoHostAssemblyNameSet>
    </PropertyGroup>

    <ItemGroup Label="RhinoWIP Host Requirements">
        <_RhinoRequiredHostFile Include="$(RhinoCommonReferencePath)" Condition="'$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true' or '$(IsRhinoCommonAwareProject)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(RhinoUiReferencePath)" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(SystemDrawingCommonReferencePath)" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(Grasshopper2ReferencePath)" Condition="'$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(GrasshopperIoReferencePath)" Condition="'$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(EtoReferencePath)" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(MicrosoftMacOSReferencePath)" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(RhinoRuntimeCodeReferencePath)" Condition="'$(IsRhinoBridgeProject)' == 'true' and '$(IsRhinoPluginProject)' == 'true'" />
        <_RhinoRequiredHostFile Include="$(RhinoCodePlatformReferencePath)" Condition="'$(IsRhinoBridgeProject)' == 'true' and '$(IsRhinoPluginProject)' == 'true'" />
    </ItemGroup>

    <PropertyGroup Label="Host And Bridge Versioning" Condition="'$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsRhinoBridgeProject)' == 'true'">
        <EnableDynamicLoading Condition="'$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true'">true</EnableDynamicLoading>
        <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
        <TargetExt Condition="'$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true'">.rhp</TargetExt>
    </PropertyGroup>

    <PropertyGroup Label="Thinktecture Identity Generators" Condition="'$(UsesThinktecture)' == 'true'">
        <!-- One public JetBrains.Annotations identity avoids Thinktecture-generated internal polyfill collisions. -->
        <ThinktectureRuntimeExtensions_SourceGenerator_GenerateJetBrainsAnnotations>false</ThinktectureRuntimeExtensions_SourceGenerator_GenerateJetBrainsAnnotations>
    </PropertyGroup>

    <ItemGroup Label="Workspace Foundation Packages" Condition="'$(IsLocalCSharpAnalyzerProject)' != 'true'">
        <PackageReference Include="JetBrains.Annotations" Condition="'$(UsesThinktecture)' == 'true'" />
        <PackageReference Include="LanguageExt.Core" Condition="'$(UseWorkspaceLibraries)' == 'true'" />
        <PackageReference Include="Thinktecture.Runtime.Extensions" Condition="'$(UseWorkspaceLibraries)' == 'true'" />
    </ItemGroup>

    <ItemGroup Label="Test Packages">
        <PackageReference Include="coverlet.MTP" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true'" />
        <PackageReference Include="CsCheck" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true' or '$(IsTestKitProject)' == 'true'" />
        <PackageReference Include="Microsoft.Testing.Extensions.CrashDump" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true'" />
        <PackageReference Include="Microsoft.Testing.Extensions.HangDump" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true'" />
        <PackageReference Include="Microsoft.Testing.Extensions.Retry" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true'" />
        <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true'" />
        <PackageReference Include="xunit.v3.assert" PrivateAssets="all" Condition="'$(IsTestKitProject)' == 'true'" />
        <PackageReference Include="xunit.v3.common" PrivateAssets="all" Condition="'$(IsTestKitProject)' == 'true'" />
        <PackageReference Include="xunit.v3.extensibility.core" PrivateAssets="all" Condition="'$(IsTestKitProject)' == 'true'" />
        <PackageReference Include="xunit.v3.mtp-v2" PrivateAssets="all" Condition="'$(IsTestProject)' == 'true'" />
    </ItemGroup>

    <ItemGroup Label="Test Usings" Condition="'$(IsTestProject)' == 'true' or '$(IsTestKitProject)' == 'true'">
        <Using Include="CsCheck" />
        <Using Include="Xunit" />
    </ItemGroup>

    <PropertyGroup Label="Test Runtime Config" Condition="'$(IsTestProject)' == 'true'">
        <OutputType>Exe</OutputType>
        <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
        <_XunitRunnerJsonContent>{"$schema":"https://xunit.net/schema/v3.1/xunit.runner.schema.json","parallelAlgorithm":"conservative","preEnumerateTheories":true,"longRunningTestSeconds":30,"printMaxEnumerableLength":64,"printMaxObjectDepth":4}</_XunitRunnerJsonContent>
    </PropertyGroup>

    <ItemDefinitionGroup Label="Test Project Reference Isolation" Condition="'$(IsTestProject)' == 'true'">
        <ProjectReference>
            <GlobalPropertiesToRemove>IsTestProject;UseMicrosoftTestingPlatformRunner;IsTestingPlatformApplication;GenerateTestingPlatformEntryPoint;GenerateSelfRegisteredExtensions</GlobalPropertiesToRemove>
        </ProjectReference>
    </ItemDefinitionGroup>

    <!-- One classification-keyed TestKit reference replaces per-test project references. -->
    <ItemGroup Label="TestKit Reference" Condition="'$(IsTestProject)' == 'true' and '$(IsAnalyzerTestProject)' != 'true'">
        <ProjectReference Include="$(TestKitRoot)Rasm.TestKit.csproj" />
    </ItemGroup>

    <!-- The scenario content home composes the host-aware scenario SDK through classification, never per-project references. -->
    <ItemGroup Label="ScenarioKit Reference" Condition="'$(HasBridgeScenarios)' == 'true'">
        <ProjectReference Include="$(TestScenarioKitRoot)Rasm.ScenarioKit.csproj" />
    </ItemGroup>

    <PropertyGroup Label="Coverage" Condition="'$(IsTestProject)' == 'true'">
        <CoverletOutputFormat>json,cobertura</CoverletOutputFormat>
        <CoverletOutput>$(MSBuildThisFileDirectory).artifacts/coverage/$(MSBuildProjectName)/</CoverletOutput>
        <CoverletInclude>[Rasm*]*,[Csp.*]*</CoverletInclude>
        <CoverletExclude>[*Tests]*,[*TestKit]*</CoverletExclude>
        <CoverletExcludeAssembliesWithoutSources>None</CoverletExcludeAssembliesWithoutSources>
        <CoverletExcludeByFile>**/obj/**;**/*.Generated.cs;**/*.g.cs</CoverletExcludeByFile>
        <CoverletExcludeByAttribute>System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute,System.CodeDom.Compiler.GeneratedCodeAttribute,System.Runtime.CompilerServices.CompilerGeneratedAttribute</CoverletExcludeByAttribute>
        <CoverletSingleHit>false</CoverletSingleHit>
        <CoverletUseSourceLink>false</CoverletUseSourceLink>
        <CoverletSkipAutoProps>true</CoverletSkipAutoProps>
        <CoverletDeterministicReport>true</CoverletDeterministicReport>
        <CoverletIncludeTestAssembly>false</CoverletIncludeTestAssembly>
    </PropertyGroup>

    <ItemGroup Label="Workspace Usings" Condition="'$(IsLocalCSharpAnalyzerProject)' != 'true' and '$(UseWorkspaceLibraries)' == 'true'">
        <Using Include="LanguageExt" />
        <Using Include="LanguageExt.Common" />
        <Using Include="LanguageExt.Effects" />
        <Using Include="LanguageExt.Prelude" Static="true" />
        <Using Include="LanguageExt.Pretty" />
        <Using Include="LanguageExt.Traits" />
        <Using Include="LanguageExt.Traits.Domain" />
        <Using Include="Thinktecture" />
    </ItemGroup>

    <ItemGroup Label="Grasshopper Thinktecture Usings" Condition="'$(IsLocalCSharpAnalyzerProject)' != 'true' and '$(UseWorkspaceLibraries)' != 'true' and ('$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true')">
        <Using Include="Thinktecture" />
    </ItemGroup>

    <!-- Colliding global namespaces demote to aliases; host namespaces stay on host-aware strata. -->
    <ItemGroup Label="Grasshopper-Aware Usings" Condition="'$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true'">
        <Using Include="Eto.Drawing" />
        <Using Include="Grasshopper2.Types.Numeric" />
        <Using Include="Grasshopper2.UI" />
        <Using Include="Rasm.Analysis" />
        <Using Include="Rasm.Domain" />
        <Using Include="Rhino.Geometry" />
        <Using Include="System.Runtime.InteropServices" />
    </ItemGroup>

    <ItemGroup Label="AppUi Avalonia Usings" Condition="'$(IsAppUiProject)' == 'true'">
        <Using Include="Avalonia" />
        <Using Include="Avalonia.Controls" />
        <Using Include="Avalonia.Input" />
        <Using Include="Avalonia.Media" />
    </ItemGroup>

    <ItemGroup Label="Assembly Visibility" Condition="$([System.String]::Copy('$(NormalizedProjectDirectory)').StartsWith('$(CSharpLibsRoot)'))">
        <InternalsVisibleTo Include="$(MSBuildProjectName).Tests" />
        <InternalsVisibleTo Include="Rasm.TestKit" />
    </ItemGroup>

    <ItemGroup Label="Kernel Assembly Visibility" Condition="'$(MSBuildProjectName)' == 'Rasm'">
        <InternalsVisibleTo Include="Rasm.Grasshopper" />
        <InternalsVisibleTo Include="Rasm.Rhino" />
    </ItemGroup>

    <ItemGroup Label="RhinoWIP Assembly Metadata" Condition="'$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true'">
        <AssemblyAttribute Include="Rhino.PlugIns.PlugInDescriptionAttribute" Condition="'$(Company)' != ''">
            <_Parameter1>Rhino.PlugIns.DescriptionType.Organization</_Parameter1>
            <_Parameter1_IsLiteral>true</_Parameter1_IsLiteral>
            <_Parameter2>$(Company)</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="Rhino.PlugIns.PlugInDescriptionAttribute" Condition="'$(RhinoPluginIconResource)' != ''">
            <_Parameter1>Rhino.PlugIns.DescriptionType.Icon</_Parameter1>
            <_Parameter1_IsLiteral>true</_Parameter1_IsLiteral>
            <_Parameter2>$(RhinoPluginIconResource)</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Runtime.InteropServices.GuidAttribute" Condition="'$(RhinoPluginAssemblyGuid)' != ''">
            <_Parameter1>$(RhinoPluginAssemblyGuid)</_Parameter1>
        </AssemblyAttribute>
    </ItemGroup>

    <ItemGroup Label="macOS Host Platform Metadata" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'">
        <AssemblyAttribute Include="System.Runtime.Versioning.SupportedOSPlatformAttribute">
            <_Parameter1>macos15.0</_Parameter1>
        </AssemblyAttribute>
    </ItemGroup>

    <ItemGroup Label="RhinoWIP Host References" Condition="'$(IsRhinoPluginProject)' == 'true' or '$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true' or '$(IsRhinoCommonAwareProject)' == 'true' or '$(NeedsRhinoHostUiSurface)' == 'true'">
        <Reference Include="Eto" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'">
            <HintPath>$(EtoReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
        <Reference Include="Grasshopper2" Condition="'$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true'">
            <HintPath>$(Grasshopper2ReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
        <Reference Include="GrasshopperIO" Condition="'$(IsGrasshopperPluginProject)' == 'true' or '$(IsGrasshopperAwareProject)' == 'true'">
            <HintPath>$(GrasshopperIoReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
        <Reference Include="Microsoft.macOS" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'">
            <HintPath>$(MicrosoftMacOSReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
        <Reference Include="Rhino.Runtime.Code" Condition="'$(IsRhinoBridgeProject)' == 'true' and '$(IsRhinoPluginProject)' == 'true'">
            <HintPath>$(RhinoRuntimeCodeReferencePath)</HintPath>
            <Private>false</Private>
        </Reference>
        <Reference Include="Rhino.UI" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'">
            <HintPath>$(RhinoUiReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
        <Reference Include="RhinoCommon">
            <HintPath>$(RhinoCommonReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
        <Reference Include="RhinoCodePlatform.Rhino3D" Condition="'$(IsRhinoBridgeProject)' == 'true' and '$(IsRhinoPluginProject)' == 'true'">
            <HintPath>$(RhinoCodePlatformReferencePath)</HintPath>
            <Private>false</Private>
        </Reference>
        <Reference Include="System.Drawing.Common" Condition="'$(NeedsRhinoHostUiSurface)' == 'true'">
            <HintPath>$(SystemDrawingCommonReferencePath)</HintPath>
            <Private>$(HostReferencePrivate)</Private>
        </Reference>
    </ItemGroup>

    <ItemGroup Label="RhinoWIP Compile Packages" Condition="'$(NeedsSystemDrawingCompilePackage)' == 'true'">
        <PackageReference Include="System.Drawing.Common" ExcludeAssets="runtime" />
    </ItemGroup>
</Project>

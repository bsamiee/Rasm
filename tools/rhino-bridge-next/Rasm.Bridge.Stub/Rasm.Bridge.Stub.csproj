<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Dependency-zero RhinoWIP stub for the rebuilt runtime bridge: one reflective activation hop into the shell ALC.</Description>
        <AssemblyName>rasm-bridge-next</AssemblyName>
        <RootNamespace>Rasm.Bridge.Stub</RootNamespace>
        <RhinoPluginAssemblyGuid>23898819-e84f-4fd3-bb2c-85b208718cba</RhinoPluginAssemblyGuid>
        <YakPackageSlug>rasm-bridge-next</YakPackageSlug>
        <!-- Load-identity stamp: proves which build the host loaded during dual-run. -->
        <InformationalVersion>0.1.0-stub</InformationalVersion>
        <!-- tools/rhino-bridge-next sits outside the path-derived plugin classification roots, and
             Directory.Build.props evaluates classification before this file participates; the
             plugin posture (and its property fallout) is therefore declared explicitly. -->
        <IsRhinoPluginProject>true</IsRhinoPluginProject>
        <UseWorkspaceLibraries>false</UseWorkspaceLibraries>
        <CspScope>Boundary</CspScope>
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
        <TargetExt>.rhp</TargetExt>
    </PropertyGroup>
</Project>

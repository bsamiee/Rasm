<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <!-- BenchmarkDotNet rejects unoptimized benchmark assemblies; assay routes benchmarks through Release closure. -->
        <Optimize>true</Optimize>
    </PropertyGroup>
    <ItemGroup Label="Benchmark Packages">
        <PackageReference Include="BenchmarkDotNet" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup Label="Assembly Metadata">
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>RasmWorkspaceRoot</_Parameter1>
            <_Parameter2>$(SolutionDir)</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>
</Project>

{
    "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "testRunner": "vitest",
    "vitest": {
        "configFile": "vitest.config.ts"
    },
    "mutate": ["libs/typescript/**/src/**/*.{ts,tsx}", "!**/*.{test,spec}.{ts,tsx}", "!**/*.d.ts"],
    "concurrency": 4,
    "dryRunTimeoutMinutes": 5,
    "timeoutMS": 5000,
    "timeoutFactor": 1.5,
    "tempDirName": ".cache/stryker/tmp",
    "incremental": true,
    "incrementalFile": ".cache/stryker/incremental.json",
    "reporters": ["html", "json"],
    "htmlReporter": {
        "fileName": ".artifacts/typescript/stryker/mutation-report.html"
    },
    "jsonReporter": {
        "fileName": ".artifacts/typescript/stryker/mutation-report.json"
    },
    "thresholds": {
        "high": 90,
        "low": 85,
        "break": 80
    }
}

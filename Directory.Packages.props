        <!-- Robots closure: the Rhino3dm managed binding (visose Robots' geometry substrate — ships a real
             runtimes/osx-arm64/native/librhino3dm_native.dylib plus osx-x64/linux/win RIDs) and the pure-managed
             SSH.NET robot-program SFTP upload path. Both MIT. SSH.NET pulls BouncyCastle.Cryptography (pure-managed
             AnyCPU), floor-pinned here so central transitive pinning stays deterministic; its
             Microsoft.Extensions.Logging.Abstractions transitive resolves upward against the existing 10.0.9 row. -->
        <PackageVersion Include="Rhino3dm" Version="8.17.0" />
        <PackageVersion Include="SSH.NET" Version="2025.1.0" />
        <PackageVersion Include="BouncyCastle.Cryptography" Version="2.6.2" />
        <!-- Apache.Arrow.Compression closure: the Arrow-IPC LZ4-frame stream codec and the pure-managed
             Zstandard port. Both pure-managed AnyCPU, no native RID asset; floor-pinned to the nuspec
             versions so central transitive pinning stays deterministic. -->
        <PackageVersion Include="K4os.Compression.LZ4.Streams" Version="1.3.8" />
        <PackageVersion Include="ZstdSharp.Port" Version="0.8.8" />
        <!-- FlowtideDotNet.Substrait closure: the SQL-text -> Substrait-plan parser (TylerBrinks/SqlParser-cs,
             pure-managed MIT, port of sqlparser-rs); floor-pinned so central transitive pinning stays deterministic. -->
        <PackageVersion Include="SqlParserCS" Version="0.6.5" />
        <!-- Confluent.SchemaRegistry.Serdes closure: the Apache Avro reference codec the Avro serde rides
             (Apache-2.0, pure-managed netstandard2.0/2.1), the protobuf-net descriptor-reflection chain the
             Protobuf serde rides, and the NJsonSchema chain the JSON-Schema serde rides. All pure-managed
             AnyCPU, floor-pinned so central transitive pinning stays deterministic. Newtonsoft.Json /
             System.CodeDom transitives ride existing higher rows. -->
        <PackageVersion Include="Apache.Avro" Version="1.12.1" />
        <PackageVersion Include="protobuf-net.Reflection" Version="3.2.52" />
        <PackageVersion Include="protobuf-net.Core" Version="3.2.56" />
        <PackageVersion Include="NJsonSchema" Version="11.6.1" />
        <PackageVersion Include="NJsonSchema.NewtonsoftJson" Version="11.6.1" />
        <PackageVersion Include="NJsonSchema.Annotations" Version="11.6.1" />
        <PackageVersion Include="Namotion.Reflection" Version="3.5.1" />
        <!-- Confluent.SchemaRegistry caching leg + the columnar/wide-column store-client Microsoft.Extensions
             floors (ClickHouse.Driver Http, ScyllaDBCSharpDriver + Minio Logging/DI/Immutable), pinned on the
             10.0.9 servicing line so central transitive pinning lifts them above the package nuspec floors. -->
        <PackageVersion Include="Microsoft.Extensions.Caching.Memory" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Http" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Logging" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9" />
        <PackageVersion Include="System.Collections.Immutable" Version="10.0.9" />
        <!-- NATS.Net closure: the eight 2.8.2 sub-clients the meta-package fans out to, plus the Abstractions
             contract, the NKeys signing primitive, and the Primitives/Hosting.Abstractions floors they pull.
             All pure-managed AnyCPU, floor-pinned for lockfile determinism; System.Memory rides the 4.6.3 row. -->
        <PackageVersion Include="NATS.Client.Core" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.Abstractions" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.Hosting" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.JetStream" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.KeyValueStore" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.ObjectStore" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.Serializers.Json" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.Services" Version="2.8.2" />
        <PackageVersion Include="NATS.Client.Simplified" Version="2.8.2" />
        <PackageVersion Include="NATS.NKeys" Version="1.0.2" />
        <PackageVersion Include="Microsoft.Extensions.Primitives" Version="10.0.9" />
        <PackageVersion Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
        <!-- Microsoft.ML.Tokenizers.Data.* closure: the 2.0.0 vocab packages pull Microsoft.Bcl.Memory 9.0.4
             which carries the GHSA-73j8-2gch-69rq advisory; floor-pinned to the patched 10.0.9 BCL servicing
             line (pure-managed AnyCPU) so central transitive pinning lifts the resolved version above the vuln. -->
        <PackageVersion Include="Microsoft.Bcl.Memory" Version="10.0.9" />
        <PackageVersion Include="Humanizer.Core" Version="3.0.10" />
        <PackageVersion Include="Microsoft.Build.Framework" Version="18.7.1" />
        <PackageVersion Include="Microsoft.Extensions.DependencyModel" Version="10.0.9" />
        <!-- Directly-invoked by AppHost configuration-and-options (OptionsBuilder.Bind/BindConfiguration,
             Configure<T>(IConfiguration), validation-on-start); explicitly pinned on the 10.0.9 servicing
             line so the central transitive pin stays deterministic. -->
        <PackageVersion Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.9" />
        <PackageVersion Include="Microsoft.NET.StringTools" Version="18.7.1" />
        <PackageVersion Include="Newtonsoft.Json" Version="13.0.4" />
        <!-- Bim GIS closure: the NTS Feature/AttributesTable surface NetTopologySuite.IO.Esri.Shapefile and
             bertt.CityJSON both require (separate package id from the NTS core); pure-managed AnyCPU. -->
        <PackageVersion Include="NetTopologySuite.Features" Version="2.2.0" />
        <!-- FlatGeobuf closure: the Newtonsoft-based GeoJSON codec (distinct package id from the admitted STJ
             GeoJSON4STJ) and the Nito async-coordination meta-package; both pure-managed AnyCPU, their
             NTS/NTS.Features/Newtonsoft.Json transitives ride existing higher rows. -->
        <PackageVersion Include="NetTopologySuite.IO.GeoJSON" Version="4.0.0" />
        <PackageVersion Include="Nito.AsyncEx" Version="5.1.2" />
        <!-- NetTopologySuite.IO.VectorTiles.Mapbox closure: the protobuf-net meta lifted to 3.2.56 (== the
             admitted protobuf-net.Core line) so the MVT codec never resolves the legacy protobuf-net 2.4.0 floor. -->
        <PackageVersion Include="protobuf-net" Version="3.2.56" />
        <!-- MPXJ.Net closure: the DateOnly/TimeOnly polyfill (net10 in-box no-op facade), lifted to the newest
             stable line; the IKVM.Maven.Sdk + IKVM build-time Java->IL translation chain resolves transitively. -->
        <PackageVersion Include="Portable.System.DateTimeOnly" Version="9.0.1" />
        <!-- Smino.Bcf.Toolkit closure: the obarlik Json.Net no-dependency serializer and the recursive
             DataAnnotations validator; both pure-managed AnyCPU, floor-pinned for lockfile determinism. -->
        <PackageVersion Include="Json.Net" Version="1.0.33" />
        <PackageVersion Include="RecursiveDataAnnotationsValidation" Version="2.2.0" />
        <!-- SwiftCollections.Lean closure: the zero-net8-dep Chronicler logging core; MIT, pure-managed AnyCPU. -->
        <PackageVersion Include="Chronicler.Core.Lean" Version="0.2.1" />
        <!-- TorchSharp closure: the model-archive deflate codec and the contiguous-memory BCL primitive it floors on.
             Both pure-managed AnyCPU; SkiaSharp 3.119.4 + Google.Protobuf 3.35.1 transitives ride existing higher rows. -->
        <PackageVersion Include="SharpZipLib" Version="1.4.2" />
        <PackageVersion Include="System.Memory" Version="4.6.3" />
        <PackageVersion Include="System.CodeDom" Version="10.0.9" />
        <PackageVersion Include="System.Management" Version="10.0.9" />
        <PackageVersion Include="System.Composition" Version="10.0.9" />
        <PackageVersion Include="System.Composition.AttributedModel" Version="10.0.9" />
        <PackageVersion Include="System.Composition.Convention" Version="10.0.9" />
        <PackageVersion Include="System.Composition.Hosting" Version="10.0.9" />
        <PackageVersion Include="System.Composition.Runtime" Version="10.0.9" />
        <PackageVersion Include="System.Composition.TypedParts" Version="10.0.9" />
        <PackageVersion Include="System.Threading.RateLimiting" Version="10.0.9" />
        <!-- MTConnect.NET-Common closure: the single managed transitive floor (YAML asset serializer)
             the cutting-tool model pulls on net9.0; lifted centrally for lockfile determinism. -->
        <PackageVersion Include="YamlDotNet" Version="18.1.0" />
        <PackageVersion Include="EPPlus" Version="8.6.1" />
        <PackageVersion Include="Snappier" Version="1.3.1" />
    </ItemGroup>

<?xml version="1.0" encoding="utf-8"?>
<!-- Hermetic restore: nuget.org is the sole source and every package id maps to it, closing
     source-substitution and user-level NuGet.config pollution. packages.lock.json contentHash
     is the integrity mechanism on macOS (package signature verification is skipped there).
     Extend the mapping when adding a source; never delete it. -->
<configuration>
    <packageSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    </packageSources>
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
    </packageSourceMapping>
    <!-- Pins the NuGetAudit vulnerability-data source explicitly so the audit gate
         (NuGetAudit/NuGetAuditMode/NuGetAuditLevel in Directory.Build.props) cannot be
         weakened by source-list edits. -->
    <auditSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    </auditSources>
</configuration>

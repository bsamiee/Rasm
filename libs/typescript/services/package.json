        "@effect/ai-google": "catalog:",
        "@effect/ai-openai": "catalog:",
        "@effect/ai-openrouter": "catalog:",
        "@effect/cli": "catalog:",
        "@effect/cluster": "catalog:",
        "@effect/experimental": "catalog:",
        "@effect/opentelemetry": "catalog:",
        "@effect/platform-node": "catalog:",
        "@effect/rpc": "catalog:",
        "@effect/sql": "catalog:",
        "@effect/sql-pg": "catalog:",
        "@effect/workflow": "catalog:",
        "@opentelemetry/sdk-trace-node": "catalog:",
        "@rasm/interchange": "workspace:*",
        "@rasm/projection": "workspace:*",
        "effect": "catalog:",
        "exceljs": "catalog:",
        "ioredis": "catalog:",

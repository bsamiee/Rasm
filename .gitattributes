# Text Normalization
# LF working-tree law for all source/config; *.verify.csx scenarios are compiler-authoritative
# and *.verified.* Verify snapshots are byte-exact assertion artifacts — both stay LF.
* text=auto
*.cs text eol=lf
*.csx text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.slnx text eol=lf
*.proto text eol=lf
*.axaml text eol=lf
*.xaml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.pyi text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.verified.* text eol=lf
*.verified.txt text eol=lf working-tree-encoding=UTF-8

# Icons
*.ico -filter -diff -merge -text

<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Collectible-ALC cargo for in-host scenario discovery, capability probes, crash-durable evidence spooling, and GH2 rendering.</Description>
        <CspScope>Boundary</CspScope>
        <AssemblyName>Rasm.Bridge.Cargo</AssemblyName>
        <RootNamespace>Rasm.Bridge.Cargo</RootNamespace>
        <!-- Cargo isolates workspace libraries per swap; host assemblies resolve through bridge classification. -->
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <InformationalVersion>0.1.0-cargo</InformationalVersion>
    </PropertyGroup>
    <ItemGroup Label="Project References">
        <ProjectReference Include="../Contract/Contract.csproj" />
        <ProjectReference Include="../../../tests/csharp/_scenariokit/Rasm.ScenarioKit.csproj" />
    </ItemGroup>
    <!-- Cargo carries no kernel closure: the Grasshopper-aware classification injects retired-kernel namespaces Cargo never uses, and the ScenarioKit supplies none transitively. -->
    <ItemGroup Label="Kernel-Free Usings">
        <Using Remove="Rasm.Analysis" />
        <Using Remove="Rasm.Domain" />
    </ItemGroup>
</Project>

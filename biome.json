{
    "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!!**/node_modules",
            "!!**/.cache",
            "!!**/.artifacts",
            "!!**/.claude/skills/**/.cache",
            "!!**/.claude/worktrees",
            "!!**/.mypy_cache",
            "!!**/.nx",
            "!!**/.parcel-cache",
            "!!**/.probes",
            "!!**/.pulumi",
            "!!**/.pytest_cache",
            "!!**/.ruff_cache",
            "!!**/.swc",
            "!!**/.venv",
            "!!**/bin",
            "!!**/obj",
            "!!**/coverage",
            "!!**/dist",
            "!!**/build",
            "!!**/packages.lock.json",
            "!!**/test-results",
            "!!**/pnpm-lock.yaml",
            "!!**/uv.lock"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 150
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended"
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}

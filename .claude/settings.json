{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "claude-opus-4-7",
    "effortLevel": "xhigh",
    "alwaysThinkingEnabled": true,
    "showThinkingSummaries": true,
    "skillListingBudgetFraction": 0.02,
    "respectGitignore": true,
    "autoMemoryEnabled": true,
    "showClearContextOnPlanAccept": true,
    "viewMode": "verbose",
    "useAutoModeDuringPlan": false,
    "claudeMdExcludes": [
        "**/.cache/**/CLAUDE.md",
        "**/node_modules/**/CLAUDE.md",
        "**/bin/**/CLAUDE.md",
        "**/obj/**/CLAUDE.md",
        "**/.artifacts/**/CLAUDE.md"
    ],
    "permissions": {
        "allow": [
            "Read",
            "Write",
            "Edit",
            "Glob",
            "Grep",
            "TaskCreate",
            "TaskUpdate",
            "TaskList",
            "TaskGet",
            "WebSearch",
            "WebFetch",
            "Skill",
            "SlashCommand",
            "Agent(Explore)",
            "Agent(Plan)",
            "Agent(general-purpose)",
            "Agent(skill-summarizer)",
            "Bash(git:*)",
            "Bash(gh:*)",
            "Bash(dotnet:*)",
            "Bash(uv run python -m tools.quality:*)",
            "Bash(rg:*)",
            "Bash(fd:*)",
            "Bash(eza:*)",
            "Bash(jq:*)",
            "Bash(pnpm:*)",
            "Bash(nx:*)",
            "Bash(curl:*)"
        ],
        "deny": [
            "Read(.env)",
            "Read(**/*.pem)",
            "Read(**/*.key)",
            "Edit(.env)",
            "Edit(**/*.pem)",
            "Edit(**/*.key)",
            "Bash(rm -rf*)",
            "Bash(git push --force*)",
            "Bash(git reset --hard*)",
            "Bash(dotnet sln*remove*)"
        ],
        "defaultMode": "acceptEdits"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-env.sh"
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {}
}

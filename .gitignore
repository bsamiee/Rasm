# --- [CACHES] -----------------------------------------------------------------

.cache/
# .artifacts/build/{bin,obj}/<token>/ is the centralized .NET build-output root (Directory.Build.props); .artifacts/{assay,coverage,rhino} hold per-run scopes and agent scratch.
**/.artifacts/
/.remember/
.nx/*
.parcel-cache/
.pulumi/
.swc/
.stryker-tmp/
test-results/mutation/stryker-incremental.json
.vite/
.scannerwork/

# --- [.NET_ARTIFACTS] ---------------------------------------------------------

**/bin/
**/obj/
**/TestResults/
diagnostics.sarif
*.rsuser
*.suo
*.lscache

# Grasshopper2.dll extracts embedded resources (icons, color dictionaries,
# .3dm crystal models, .ghicon bitmaps, .ghdic) to the cwd of `dotnet build`
# whenever Grasshopper2 is referenced. Root-anchored so we don't shadow the
# real `apps/grasshopper/` tree.
/Grasshopper.*


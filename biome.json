{
    "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true,
        "defaultBranch": "main"
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!!**/node_modules",
            "!!**/.cache",
            "!!**/.artifacts",
            "!!**/.mypy_cache",
            "!!**/.nx",
            "!!**/.parcel-cache",
            "!!**/.probes",
            "!!**/.pulumi",
            "!!**/.pytest_cache",
            "!!**/.ruff_cache",
            "!!**/.swc",
            "!!**/.venv",
            "!!**/.history",
            "!!**/bin",
            "!!**/obj",
            "!!**/dist",
            "!!**/build",
            "!!**/_tmp",
            "!!**/packages.lock.json",
            "!!**/pnpm-lock.yaml",
            "!!**/uv.lock",
            "!!**/.archive",
            "!!**/_archive",
            "!!**/scratch",
            "!!**/.scratch",
            "!!**/.tmp",
            "!!.claude/workflows",
            "!!.claude/skills/workflow-creator/assets",
            "!!**/*.html"
        ]
    },
    "plugins": [
        {
            "path": "./tools/biome/no-arity-sibling.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-await-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-barrel-reexport.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-blanket-catchall.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-domain-throw.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-fetch-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-mutable-accumulation.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-nullable-return.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-process-env-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-rename-wrapper.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-run-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-standalone-brand.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        },
        {
            "path": "./tools/biome/no-stdlib-in-domain.grit",
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"]
        }
    ],
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 150
    },
    "linter": {
        "enabled": true,
        "domains": {
            "project": "none",
            "test": "recommended",
            "types": "none"
        },
        "rules": {
            "preset": "recommended",
            "complexity": {
                "useLiteralKeys": "off"
            },
            "performance": {
                "noAccumulatingSpread": "error",
                "noBarrelFile": "error",
                "noDelete": "error",
                "noReExportAll": "error"
            },
            "suspicious": {
                "noExplicitAny": "error",
                "noShadowRestrictedNames": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "json": {
        "parser": {
            "allowComments": true
        }
    },
    "overrides": [
        {
            "includes": ["tests/typescript/e2e/platform/blocked.pw.ts"],
            "linter": {
                "enabled": false
            }
        },
        {
            "includes": [".claude/skills/applescript/assets/**"],
            "linter": {
                "rules": {
                    "correctness": {
                        "noUnusedVariables": "off"
                    },
                    "suspicious": {
                        "noRedundantUseStrict": "off"
                    }
                }
            }
        },
        {
            "includes": [".claude/skills/workflow-creator/scripts/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noAssignInExpressions": "off",
                        "noTemplateCurlyInString": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/libs/typescript/**", "!**/*.spec.*", "!**/*.test.*", "!**/*.bench.*"],
            "linter": {
                "rules": {
                    "style": {
                        "noDefaultExport": "error"
                    },
                    "suspicious": {
                        "noConsole": "error"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}

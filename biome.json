{
    "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": [
            "**",
            "!**/node_modules",
            "!**/.cache",
            "!**/.claude/skills/**/.cache",
            "!**/.claude/worktrees",
            "!**/.nx",
            "!**/.venv",
            "!**/bin",
            "!**/obj",
            "!**/coverage",
            "!**/dist",
            "!**/test-results"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    }
}

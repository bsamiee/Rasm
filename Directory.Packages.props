    <!-- Fabrication: manufacturing-specific pins only; computational geometry substrates live in Geometry Kernel. -->
    <ItemGroup Label="Fabrication">
        <PackageVersion Include="RectpackSharp" Version="1.2.0" />
        <!-- Robots (visose): host-neutral managed serial-chain robot kinematics — per-mechanism DH/Modified-DH
             forward kinematics, closed-form ANALYTIC IK (spherical/offset-wrist) discriminated by RobotConfigurations,
             a NumericalKinematics fallback, joint-limit/singularity/reach-envelope validation stamped into a
             KinematicSolution, multi-mechanism groups + external-axis (track/positioner) kinematics, and the
             ABB/KUKA/UR/Staubli/Franka/Doosan/Fanuc/Igus/Jaka cell models. MIT, net8.0 lib binds forward under
             net10.0. Supersedes the hand-rolled DH-FK + damped-least-squares IK in Toolpath/kinematics.md.
             Transitive floors Rhino3dm + SSH.NET (+ BouncyCastle.Cryptography) pinned in Transitive Floors. -->
        <PackageVersion Include="Robots" Version="2.1.2" />
        <!-- PicoGK (LEAP71): the implicit/SDF/voxel geometry kernel for additive manufacturing — IImplicit ->
             Voxels(IImplicit,BBox3) TPMS/gyroid infill, Lattice.AddBeam/AddSphere -> Voxels(Lattice) support
             scaffolds, GetVoxelSlice + CliIo/Vdb2Cli SLA/DLP/MSLA layer-stack rasterization, 3D SDF Boolean +
             Offset/Fillet, OpenVdbFile I/O. COMPANION / OUTSIDE-RHINO: lib/net9.0-only + bundled
             runtimes/osx-arm64/native/picogk.dylib firebreaks it out of any net48 in-Rhino ALC. Apache-2.0.
             Sole dependency SkiaSharp >=3.119.0 rides the existing App UI 3.119.4 row (no new floor). -->
        <PackageVersion Include="PicoGK" Version="2.2.0" />
        <!-- MTConnect.NET-Common (TrakHound): the ISO-13399-aligned MTConnect cutting-tool asset model
             (MTConnect.Assets.CuttingTools — CuttingToolAsset/CuttingToolLifeCycle/CuttingItem/Measurement +
             ToolLife/CutterStatus) backing the tool-data MODEL half of the Magazine/ToolAssembly catalogue.
             Lean model-only sub-package (no HTTP/MQTT/SHDR/Agent). Pure-managed AnyCPU net9.0, MIT;
             YamlDotNet resolves through the central 18.1.0 floor. -->
        <PackageVersion Include="MTConnect.NET-Common" Version="6.9.0.2" />
        <!-- OcctNet.Wrapper: the first managed 3D solid-CAD / B-rep ingress in Fabrication — STEP AP203/AP214/AP242
             and IGES read (ImportStep/ImportIges -> OcctShape, OcctFace/OcctEdge/OcctWire topology, OcctMesh
             tessellation) + ExportStep/Iges/Stl, primitive modeling + boolean fuse/cut/common over OCCT 7.9.3.
             Ships lib/net10.0 + a REAL runtimes/osx-arm64/native OCCT 7.9.3 build (dynamic-link, LGPL-2.1-with-
             OCCT-exception-1.0 clean). Wrapper MIT. plan-cs boundary-maps at the OcctShape/OcctMesh seam. -->
        <PackageVersion Include="OcctNet.Wrapper" Version="0.1.1" />
        <PackageVersion Include="DSTV.Net" Version="1.3.0" />
    </ItemGroup>


<Project>
    <!-- Scenario-project import: emits bridge-closure.json (assemblies + host-plugin GUIDs +
         built-against HostFingerprint) into the output dir at build time. The supervisor READS
         this manifest (Evidence.Stage) and never spawns MSBuild at stage time. Copy-local lock
         file assemblies make the output dir carry the FULL restored closure the cargo ships. -->
    <PropertyGroup>
        <CopyLocalLockFileAssemblies Condition="'$(CopyLocalLockFileAssemblies)' == ''">true</CopyLocalLockFileAssemblies>
    </PropertyGroup>
    <Target Name="EmitBridgeClosure" AfterTargets="Build" Condition="'$(TargetFileName)' != ''">
        <GetAssemblyIdentity AssemblyFiles="$(RhinoCommonReferencePath)" Condition="Exists('$(RhinoCommonReferencePath)')">
            <Output TaskParameter="Assemblies" ItemName="_BridgeRhinoIdentity" />
        </GetAssemblyIdentity>
        <GetAssemblyIdentity AssemblyFiles="$(Grasshopper2ReferencePath)" Condition="Exists('$(Grasshopper2ReferencePath)') and @(Reference->AnyHaveMetadataValue('Identity', 'Grasshopper2'))">
            <Output TaskParameter="Assemblies" ItemName="_BridgeGh2Identity" />
        </GetAssemblyIdentity>
        <ItemGroup>
            <_BridgeClosureAssembly Include="$(TargetFileName);@(ReferenceCopyLocalPaths->WithMetadataValue('DestinationSubDirectory','')->WithMetadataValue('Extension','.dll')->'%(Filename)%(Extension)')" />
            <_BridgeHostPlugin Include="8307876d-a461-4daa-bb77-eb3715925513" Condition="'@(_BridgeGh2Identity)' != ''" />
        </ItemGroup>
        <PropertyGroup>
            <!-- bundleVersion proxy: the WIP bundle stamps RhinoCommon.dll with the app build version (ShellHost reports RhinoApp.Version on the running side). -->
            <_BridgeBuiltAgainst>{"bundleVersion":"@(_BridgeRhinoIdentity->'%(Version)')","rhinoCommonVersion":"@(_BridgeRhinoIdentity->'%(Version)')","grasshopper2Version":"@(_BridgeGh2Identity->'%(Version)')","runtimeVersion":"$(TargetFrameworkVersion.TrimStart('v'))"}</_BridgeBuiltAgainst>
            <_BridgeClosureJson>{"assemblies":[@(_BridgeClosureAssembly->Distinct()->'"%(Identity)"', ',')],"hostPlugins":[@(_BridgeHostPlugin->'"%(Identity)"', ',')],"builtAgainst":$(_BridgeBuiltAgainst)}</_BridgeClosureJson>
        </PropertyGroup>
        <WriteLinesToFile File="$(TargetDir)bridge-closure.json" Lines="$(_BridgeClosureJson)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    </Target>
</Project>

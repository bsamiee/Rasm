<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>U7 acceptance artifact: imports tests/csharp/_testkit/Scenarios.targets like a scenario project, then feeds its own build-emitted bridge-closure.json to the real Evidence.Stage. Not production code; not in Workspace.slnx.</Description>
        <OutputType>Exe</OutputType>
        <AssemblyName>Rasm.Bridge.Supervisor.Tests</AssemblyName>
        <RootNamespace>Rasm.Bridge.ClosureProbe</RootNamespace>
        <SkipLocalCSharpAnalyzerReference>true</SkipLocalCSharpAnalyzerReference>
        <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
        <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
        <AnalysisLevel>none</AnalysisLevel>
        <NoWarn>$(NoWarn);MA0004;MA0006;MA0007;MA0011;MA0032;MA0040;MA0042;MA0045;MA0047;MA0074;MA0134;VSTHRD002;VSTHRD103;VSTHRD110;VSTHRD111;VSTHRD200</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="../../Rasm.Bridge.Supervisor/Rasm.Bridge.Supervisor.csproj" />
        <!-- Host refs in the exact Private=false shape Directory.Build.props gives scenario projects. -->
        <Reference Include="RhinoCommon">
            <HintPath>$(RhinoCommonReferencePath)</HintPath>
            <Private>false</Private>
        </Reference>
        <Reference Include="Grasshopper2">
            <HintPath>$(Grasshopper2ReferencePath)</HintPath>
            <Private>false</Private>
        </Reference>
    </ItemGroup>
    <Import Project="../../../../tests/csharp/_testkit/Scenarios.targets" />
</Project>

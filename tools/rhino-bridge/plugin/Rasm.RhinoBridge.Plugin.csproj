<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>RhinoWIP live-process validation bridge for Rasm assemblies.</Description>
        <RootNamespace>Rasm.RhinoBridge</RootNamespace>
        <RhinoPluginAssemblyGuid>c6a6b65c-4c58-485e-bd50-f805d14abe42</RhinoPluginAssemblyGuid>
        <YakManifestDirectory>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', '..', '..', '..', 'tools', 'yak', 'rasm-bridge'))</YakManifestDirectory>
        <YakPackageSlug>rasm-bridge</YakPackageSlug>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../contracts/Rasm.RhinoBridge.Contracts.csproj" />
        <ProjectReference Include="../protocol/Rasm.RhinoBridge.Protocol.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="Rasm.RhinoBridge.Contracts" />
        <Using Include="Rasm.RhinoBridge.Protocol" />
        <Using Include="Rhino" />
        <Using Include="Rhino.Commands" />
        <Using Include="Rhino.PlugIns" />
        <Using Include="System.Diagnostics" />
        <Using Include="System.Globalization" />
        <Using Include="System.IO.Pipes" />
        <Using Include="System.Reflection" />
        <Using Include="System.Runtime.CompilerServices" />
        <Using Include="System.Runtime.Loader" />
        <Using Include="System.Runtime.Versioning" />
        <Using Include="System.Text" />
        <Using Include="System.Text.Json" />
    </ItemGroup>
</Project>

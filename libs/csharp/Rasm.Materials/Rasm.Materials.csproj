<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Host-neutral AEC-domain materials: the polymorphic Profile owner over the masonry/CMU/steel/timber/glazing family axis, the measured appearance engine (node graph, closed BSDF lobe family, material library, procedural texture/photometric admission), and the host-neutral element-assembly-layout construction data model.</Description>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../Rasm/Rasm.csproj" />
    </ItemGroup>

    <ItemGroup Label="Color Spectral">
        <PackageReference Include="Wacton.Unicolour" />
        <PackageReference Include="Wacton.Unicolour.Datasets" />
    </ItemGroup>

    <ItemGroup Label="Quantities">
        <PackageReference Include="UnitsNet" />
    </ItemGroup>

    <ItemGroup Label="Section Catalogue">
        <!-- Published AISC v16.0 + EN 10365 structural-section database as typed profile classes carrying
             real UnitsNet.Length section geometry; grounds the Profiles steel/EN section seed in registered
             data instead of hand-keyed rows, composing the in-folder UnitsNet quantity owner. -->
        <PackageReference Include="VividOrange.Profiles.Catalogue" />
        <!-- Arbitrary closed-polygon section-property solver — the COMPUTATION complement to the
             VividOrange.Profiles.Catalogue section data: one shoelace/Green's-theorem solver over any
             IPerimeter replaces the per-family rectangular section-property literals across the Profiles
             families (timber/CMU/masonry/composite), composing the in-folder UnitsNet quantity owner. -->
        <PackageReference Include="VividOrange.Sections.SectionProperties" />
        <!-- Concrete impls of the ISections reinforcement floor — ConcreteSection/Section + Rebar/Link/
             LongitudinalReinforcement + layout engines + the EN-10080 BarDiameter catalogue — making the admitted
             ConcreteSectionProperties RC transformed-section solver constructible end-to-end and owning the
             reinforced-concrete section + rebar-layout the Connection/reinforcement seam composes. -->
        <PackageReference Include="VividOrange.Sections" />
    </ItemGroup>

    <ItemGroup Label="Structural Material Data">
        <!-- EN/Eurocode structural-material grade DATA owner of the in-folder VividOrange.IMaterials floor:
             EnConcrete/EnSteel/EnRebar grade->property factories (EN1992-1-1 / EN1993-1-1 Table 3.1, partial
             factors, EN 10025-5 corrosion rules) + the BiLinear/LinearElastic/ParabolaRectangle constitutive
             models, replacing hand-keyed material-grade rows and feeding the RC transformed-section path. -->
        <PackageReference Include="VividOrange.Materials" />
        <!-- Eurocode standard/identity DATA (En1990..En1999 + NationalAnnex) the material grades reference and
             the design pages cite, replacing inline design-code literals; also the Materials transitive floor. -->
        <PackageReference Include="VividOrange.Standards" />
    </ItemGroup>

    <ItemGroup Label="Section Capacity Engine">
        <!-- RC/steel column biaxial Force-Moment-Moment (N-M-M / P-M onion) capacity-surface engine: meshes the
             concrete+rebar section, sweeps strain planes, integrates fibre stress, and emits the IForceMomentMesh
             3D capacity hull — the additive interaction-diagram capability the elastic-only SectionProperties
             solver does not compute, composing the in-folder VividOrange.Sections + VividOrange.Materials. -->
        <PackageReference Include="VividOrange.InteractionDiagram" />
    </ItemGroup>

    <ItemGroup Label="Layout Packing">
        <!-- Construction 2D rectangle bin-packing / cutting-stock owner for sheet/stock-material
             arrangement and material-utilization: MaxRects/Skyline/Guillotine/Shelf + SingleBin mass-cut
             with explicit heuristic enums. The in-folder packing pin (Materials, an AEC-DOMAIN peer, cannot
             reach Fabrication's nesting kernel; AEC peers depend only upward to the Rasm kernel). -->
        <PackageReference Include="RectangleBinPack.CSharp" />
    </ItemGroup>

    <ItemGroup Label="Numerics">
        <!-- Direct AEC-domain dependency for the acquisition MeasuredBrdf overdetermined GGX/Smith least-squares
             fit (thin-QR Gauss-Newton, the algorithms-doc ROUTE_SPINE dense-overdetermined route). NOT a Rasm.Compute
             edge — the acyclic strata forbids the AEC->app-platform reference; this is Materials' own pin. The
             photometric and properties unit coercion is owned the same way: UnitsNet is admitted IN-FOLDER at
             Appearance/photometric and Properties/properties, never reaching DOWN to the Rasm.Compute units owner —
             the strata-correct seam the Rasm.Compute Symbolic/units owner and ARCHITECTURE [04]/[05] enshrine. -->
        <PackageReference Include="MathNet.Numerics" />
    </ItemGroup>

    <ItemGroup Label="Wire Serializers">
        <!-- The Thinktecture generated System.Text.Json + MessagePack codecs the Appearance/Interchange MaterialWire /
             MtlxDocument projection serializes the SmartEnum/Union/ValueObject wire shapes through, replacing the
             hand-rolled CultureInfo.InvariantCulture ToString('R') string projection — the C# sole-producer mints one
             generated codec and the TS/Python peers decode the same shape. The MessagePack heavy-transitive branch
             scopes to the companion/outside-Rhino wire; the in-Rhino ALC stays STJ-only per the Speckle.Sdk firebreak. -->
        <PackageReference Include="Thinktecture.Runtime.Extensions.Json" />
        <PackageReference Include="Thinktecture.Runtime.Extensions.MessagePack" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="System.Collections.Frozen" />
    </ItemGroup>
</Project>

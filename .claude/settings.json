{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-env.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "claudeMdExcludes": [
    "**/.cache/**/CLAUDE.md",
    "**/node_modules/**/CLAUDE.md",
    "**/bin/**/CLAUDE.md",
    "**/obj/**/CLAUDE.md",
    "**/.artifacts/**/CLAUDE.md"
  ],
  "permissions": {
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "enabledPlugins": {}
}

<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Description>Collectible-ALC cargo for in-host scenario discovery, capability probes, crash-durable evidence spooling, and GH2 rendering.</Description>
        <AssemblyName>Rasm.Bridge.Cargo</AssemblyName>
        <RootNamespace>Rasm.Bridge.Cargo</RootNamespace>
        <!-- Cargo isolates workspace libraries per swap; host assemblies resolve through bridge classification. -->
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <InformationalVersion>0.1.0-cargo</InformationalVersion>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="../Contract/Contract.csproj" />
        <ProjectReference Include="../../../tests/csharp/_testkit/Rasm.TestKit.csproj" />
    </ItemGroup>
</Project>
